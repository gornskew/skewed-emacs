#!/bin/sh
# compose-dev — POSIX sh; works with bash, dash, zsh, and macOS /bin/sh
# No bash arrays, no [[ ]], no shopt, no mapfile, no bash-specific constructs.

# =============================================================================
# COMPOSE FILE COLLECTION
#
# POSIX sh has no arrays. COMPOSE_FILES is a newline-delimited string of
# compose file paths, built once at startup. All docker compose invocations
# go through run_compose(), which reconstructs "-f file" pairs from it.
# =============================================================================

cd "${0%/*}"

export DOCKER_CONFIG="${HOME}/.docker"
SCRIPT_DIR="$(pwd)"

# Collect compose files into newline-delimited COMPOSE_FILES.
# Order: base -> sorted non-dev overlays -> sorted dev overlays.
_collect_compose_files() {
    _base=""
    _others=""
    _devs=""

    [ -f "./docker-compose.yml" ] && _base="./docker-compose.yml"

    for _f in ./*.yml; do
        [ -f "$_f" ] || continue              # manual nullglob: skip if no match
        _n="${_f##*/}"
        [ "$_n" = "docker-compose.yml" ] && continue
        case "$_n" in
            *-dev-*) _devs="${_devs:+$_devs
}$_f" ;;
            *)       _others="${_others:+$_others
}$_f" ;;
        esac
    done

    [ -n "$_others" ] && _others="$(printf '%s\n' $_others | sort)"
    [ -n "$_devs"   ] && _devs="$(printf '%s\n' $_devs   | sort)"

    COMPOSE_FILES="${_base}${_others:+
$_others}${_devs:+
$_devs}"
}

_collect_compose_files

# =============================================================================
# run_compose ARGS...
#
# Invoke docker compose with all -f flags prepended. Each arg is individually
# single-quote-escaped before eval so args containing parens, spaces, etc. work.
# =============================================================================
_quote_arg() {
    printf "'"
    printf '%s' "$1" | sed "s/'/'\\''/g"
    printf "'"
}

run_compose() {
    _rc_fargs=""
    while IFS= read -r _cf; do
        [ -n "$_cf" ] && _rc_fargs="$_rc_fargs -f $(_quote_arg "$_cf")"
    done << _FILELIST
$COMPOSE_FILES
_FILELIST

    _rc_caller=""
    for _a in "$@"; do
        _rc_caller="$_rc_caller $(_quote_arg "$_a")"
    done

    eval "$COMPOSE_CMD $_rc_fargs $_rc_caller"
}

# =============================================================================
# COLOR OUTPUT
# printf %b interprets \033 escapes; works in bash, dash, zsh, macOS sh.
# =============================================================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

log_info()    { printf "%b\n" "${BLUE}[INFO]${NC} $1"; }
log_success() { printf "%b\n" "${GREEN}[SUCCESS]${NC} $1"; }
log_warning() { printf "%b\n" "${YELLOW}[WARNING]${NC} $1"; }
log_error()   { printf "%b\n" "${RED}[ERROR]${NC} $1"; }

# =============================================================================
# PREFLIGHT
# =============================================================================
preflight_checks() {
    _pf_ok=true

    if ! command -v docker > /dev/null 2>&1; then
        echo ""
        echo "╔══════════════════════════════════════════════════════════════════╗"
        echo "║  ERROR: docker not found on PATH                                ║"
        echo "╠══════════════════════════════════════════════════════════════════╣"
        echo "║  Install Docker Desktop (macOS/Windows) or Docker Engine (Linux)║"
        echo "║  https://www.docker.com/products/docker-desktop/                ║"
        echo "╚══════════════════════════════════════════════════════════════════╝"
        echo ""
        _pf_ok=false
    elif ! docker info > /dev/null 2>&1; then
        echo ""
        echo "╔══════════════════════════════════════════════════════════════════╗"
        echo "║  ERROR: docker is installed but not running / not accessible    ║"
        echo "╠══════════════════════════════════════════════════════════════════╣"
        echo "║  macOS/Windows: start Docker Desktop and wait for green status  ║"
        echo "║  Linux:         sudo systemctl start docker                     ║"
        echo "╚══════════════════════════════════════════════════════════════════╝"
        echo ""
        _pf_ok=false
    fi

    [ "$_pf_ok" = "true" ]
}


# =============================================================================
# DOCKER COMPOSE DETECTION + FILE LIST DISPLAY
# =============================================================================
check_docker_compose() {
    if docker compose version > /dev/null 2>&1; then
        COMPOSE_CMD="docker compose"
    elif docker-compose version > /dev/null 2>&1; then
        COMPOSE_CMD="docker-compose"
    else
        log_error "Neither 'docker compose' nor 'docker-compose' is available"
        exit 1
    fi

    log_info "Using: $COMPOSE_CMD"
    log_info "Compose files (application order - later files override earlier):"

    while IFS= read -r _full_path; do
        [ -n "$_full_path" ] || continue
        _fn="${_full_path##*/}"
        case "$_fn" in
            docker-compose.yml)
                log_info "  - ${CYAN}${_fn}${NC}  ${BLUE}(base)${NC}" ;;
            *-dev-*)
                log_info "  - ${MAGENTA}${_fn}${NC}  ${YELLOW}(dev overlay)${NC}" ;;
            *)
                log_info "  - ${GREEN}${_fn}${NC}  ${GREEN}(added services)${NC}" ;;
        esac
    done << _FILELIST
$COMPOSE_FILES
_FILELIST
}

# =============================================================================
# ENVIRONMENT INIT
# =============================================================================
init_env() {
    PROJECTS_DIR="${PROJECTS_DIR:-${HOME}/projects}"
    export PROJECTS_DIR

    # stat flag differs: Linux -c '%g', macOS -f '%g'
    if [ -S "/var/run/docker.sock" ]; then
        DOCKER_GROUP_ID="$(stat -c '%g' /var/run/docker.sock 2>/dev/null \
            || stat -f '%g' /var/run/docker.sock 2>/dev/null \
            || echo 999)"
        export DOCKER_GROUP_ID
        log_info "Detected Docker group ID: $DOCKER_GROUP_ID"
    else
        export DOCKER_GROUP_ID=999
        log_warning "Docker socket not found, using default group ID: 999"
    fi

    if [ ! -d "$PROJECTS_DIR" ]; then
        log_info "Creating projects directory: $PROJECTS_DIR"
        mkdir -p "$PROJECTS_DIR"
    fi
}

ensure_env() {
    "${SCRIPT_DIR}/generate-env.sh"
}

# =============================================================================
# HELP
# =============================================================================
show_help() {
    cat << EOF
Docker Compose Management for Skewed Emacs + Gendl Development Environment

USAGE:
    $0 <command> [options]

COMMANDS:
    up [service...]     Start services (default: all services)
    down               Stop and remove all services
    restart [service]  Restart service(s)
    stop [service]     Stop service(s) without removing
    logs [service]     Show logs for service(s)
    status             Show status of all services
    ps                 Show running containers
    emacs              Connect to Emacs via emacsclient
    pull               Pull missing images (use PULL_ALWAYS=1 to pull latest)
    clean              Remove containers, networks, and images
    init               Initialize environment (.env setup via generate-env.sh)
    install-shell-functions  Write eskew/egskew helpers to shell RC file(s)
    config             Show merged Docker Compose configuration

SERVICES:
    Services are defined in docker-compose.yml and any other .yml files
    in this directory (generated from services.sexp, the editable SSoT).

EXAMPLES:
    $0 up                    # Start all services
    $0 up --pull             # Start all services and pull latest images
    $0 up <service>          # Start only one service
    $0 up --pull <service>   # Start one service and pull latest image
    $0 logs <service>        # Show service logs
    PROJECTS_DIR=/path/to/projects $0 up   # Use a custom projects directory
    $0 emacs                 # Connect to Emacs interactively
    $0 config                # Show merged configuration

ENVIRONMENT:
    .env is generated by ./generate-env.sh; do not edit it directly.
    Additional .yml files in the current directory are automatically included.

    Key variables:
        PROJECTS_DIR    Projects directory to mount (default: ~/projects)

NETWORK:
    Services communicate via Docker network 'skewed-emacs-network'
    - From host: localhost:<host-port>
    - Inter-container: <service-hostname>:<container-port>

EOF
}

# =============================================================================
# SERVICE MANAGEMENT
# =============================================================================
start_services() {
    _ss_services="$*"
    init_env
    ensure_env

    # Ensure AI TUI auth placeholder files exist on host.
    # (Docker bind-mounts create directories for missing files, breaking TUIs.)
    for _auth_file in \
        "${HOME}/.claude/.credentials.json" \
        "${HOME}/.gemini/google_accounts.json" \
        "${HOME}/.gemini/oauth_creds.json" \
        "${HOME}/.codex/auth.json"
    do
        if [ ! -f "$_auth_file" ]; then
            mkdir -p "$(dirname "$_auth_file")"
            touch "$_auth_file"
            log_info "Created placeholder: $_auth_file"
        fi
    done

    pull_images

    log_info "Starting services: ${_ss_services:-all}"
    # shellcheck disable=SC2086  (word-split intentional: service names)
    run_compose up -d $_ss_services

    # ---- MCP config merge ----
    log_info "Preparing MCP configurations (JSON + TOML)..."

    # Step 1: Copy overlay MCP config files into container
    for _overlay in \
        "${SCRIPT_DIR}/mcp/"*-mcp-windows.json \
        "${SCRIPT_DIR}/mcp/"*-mcp-container.json \
        "${SCRIPT_DIR}/mcp/"*-mcp.toml
    do
        [ -f "$_overlay" ] || continue
        log_info "Copying overlay: $(basename "$_overlay")"
        run_compose cp "$_overlay" \
            skewed-emacs:/home/emacs-user/skewed-emacs/mcp/ 2>/dev/null || true
    done

    # Step 1b: Copy overlay services-generated Emacs files
    for _overlay in "${SCRIPT_DIR}/dot-files/emacs.d/etc/"*-services-generated.el; do
        [ -f "$_overlay" ] || continue
        log_info "Copying overlay: $(basename "$_overlay")"
        run_compose cp "$_overlay" \
            skewed-emacs:/home/emacs-user/skewed-emacs/dot-files/emacs.d/etc/ 2>/dev/null || true
    done

    # Step 2: Merge inside container — retry loop for emacs daemon startup
    MCP_MERGE_SUCCESS=false
    _attempt=1
    while [ "$_attempt" -le 5 ]; do
        if run_compose exec -T skewed-emacs emacsclient --eval \
            "(progn (setenv \"SKEWED_CLONE_PATH\" \"${SCRIPT_DIR}\")
                    (load-file \"/home/emacs-user/skewed-emacs/mcp/merge-mcp-configs.el\")
                    (skewed-merge-all-mcp-configs \"/home/emacs-user/skewed-emacs/mcp\"))" \
            > /dev/null 2>&1
        then
            MCP_MERGE_SUCCESS=true
            break
        fi
        if [ "$_attempt" -lt 5 ]; then
            log_info "Waiting for emacs daemon (attempt $_attempt/5)..."
            sleep 2
        fi
        _attempt=$((_attempt + 1))
    done

    # Step 3: Copy merged Windows config back to host clone
    if [ "$MCP_MERGE_SUCCESS" = "true" ]; then
        run_compose cp \
            skewed-emacs:/tmp/merged-mcp-windows.json \
            "${SCRIPT_DIR}/mcp/claude_desktop_config.json" 2>/dev/null || true

        if [ -f "${SCRIPT_DIR}/mcp/claude_desktop_config.json" ]; then
            log_success "MCP configurations ready (container CLI, Windows, Codex)"
            log_info "Claude Desktop users: copy mcp/claude_desktop_config.json to %APPDATA%\\Claude\\"
        else
            log_success "MCP configurations ready (container CLI, Codex)"
        fi
    else
        log_warning "MCP config merge failed (emacsclient not ready yet?)"
    fi
}

stop_services() {
    log_info "Stopping all services"
    run_compose down
}

restart_services() {
    log_info "Restarting services: ${*:-all}"
    run_compose restart "$@"
}

show_logs() {
    run_compose logs -f "$@"
}

show_status() {
    log_info "Service status:"
    run_compose ps
}

connect_emacs() {
    log_info "Connecting to Emacs via emacsclient"
    run_compose exec skewed-emacs emacsclient -t
}

pull_images() {
    if [ -n "${NO_PULL}" ]; then
        log_info "Skipping pull (NO_PULL set)"
        return
    fi

    if [ -n "${PULL_ALWAYS}" ]; then
        log_info "Pulling latest images (PULL_ALWAYS set)"
        run_compose pull
        return
    fi

    log_info "Pulling missing images only"

    _svc_img_pairs="$(
        run_compose config | awk '
            $1 == "services:" { in_services=1; next }
            in_services && match($0, /^[[:space:]]{2}[A-Za-z0-9_-]+:$/) {
                service=$1; sub(":", "", service); next
            }
            in_services && $1 == "image:" { print service, $2 }
        '
    )"

    _missing=""
    while IFS=" " read -r _svc _img; do
        [ -z "$_svc" ] || [ -z "$_img" ] && continue
        if docker image inspect "$_img" > /dev/null 2>&1; then
            log_info "Image present locally, skipping pull: $_svc ($_img)"
        else
            _missing="${_missing:+$_missing }$_svc"
        fi
    done << _PAIRS
$_svc_img_pairs
_PAIRS

    if [ -z "$_missing" ]; then
        log_success "All images present locally; skipping pull"
        return
    fi

    log_info "Pulling missing services: $_missing"
    # shellcheck disable=SC2086  (word-split intentional: service names)
    run_compose pull $_missing
}

clean_all() {
    log_warning "This will remove containers, networks, and unused images (including pulled ones)"
    printf "Are you sure? (y/N): "
    read -r REPLY
    case "$REPLY" in
        [Yy]*)
            log_info "Cleaning up..."
            run_compose down --rmi all --volumes --remove-orphans
            docker system prune -f
            log_success "Cleanup complete"
            ;;
        *)
            log_info "Cleanup cancelled"
            ;;
    esac
}

show_config() {
    log_info "Showing merged Docker Compose configuration"
    run_compose config
}

# =============================================================================
# SHELL FUNCTION INSTALLATION
#
# Detects the user's login shell and writes to the appropriate RC file(s).
# Supports bash (.bashrc), zsh (.zshrc), and generic POSIX (.profile).
# Also updates .bash_profile / .zprofile if they already exist (macOS).
# =============================================================================
install_shell_functions() {
    _isf_dir="${HOME}/.config/skewed-emacs"
    _isf_file="${_isf_dir}/shell-functions.sh"

    mkdir -p "${_isf_dir}"

    # The snippet is pure POSIX sh — works when sourced from any shell.
    cat > "${_isf_file}" << 'SNIPPET'
# Skewed Emacs shell helpers - auto-generated by compose-dev
# Works in bash, zsh, sh, or any POSIX-compatible shell.

eskew() {
    docker exec -it --detach-keys "ctrl-^" skewed-emacs emacsclient -t "$@"
}

egskew() {
    docker exec -it --detach-keys "ctrl-^" skewed-emacs emacsclient -c "$@" &
}
SNIPPET

    log_success "Shell functions written to ${_isf_file}"

    # Use '.' not 'source' — POSIX portable
    _isf_source_line=". \"${_isf_file}\""

    # Primary RC based on login shell
    case "${SHELL##*/}" in
        zsh)  _isf_primary="${HOME}/.zshrc" ;;
        bash) _isf_primary="${HOME}/.bashrc" ;;
        ksh)  _isf_primary="${HOME}/.kshrc" ;;
        *)    _isf_primary="${HOME}/.profile" ;;
    esac

    touch "$_isf_primary" 2>/dev/null || true

    _isf_wrote=false
    # Write to primary, and also to .bash_profile / .zprofile if they exist
    for _isf_rc in "$_isf_primary" "${HOME}/.bash_profile" "${HOME}/.zprofile"; do
        [ -f "$_isf_rc" ] || continue
        if grep -qF "skewed-emacs/shell-functions.sh" "$_isf_rc" 2>/dev/null; then
            log_info "Shell helpers already in ${_isf_rc} (no change needed)"
        else
            printf '\n# Skewed Emacs shell helpers\n%s\n' "$_isf_source_line" >> "$_isf_rc"
            log_success "Added skewed-emacs shell helpers to ${_isf_rc}"
            _isf_wrote=true
        fi
    done

    [ "$_isf_wrote" = "true" ] && \
        log_info "Open a new terminal (or source the RC file shown above) to activate eskew/egskew"
}

show_skew_welcome() {
    echo ""
    echo "Services are Up."
    echo ""
    echo "Shell Commands for the Skewed Emacs Stack"
    echo ""
    printf "%b\n" "  \`eskew\`  ${BLUE}-- terminal emacsclient (attach in current terminal)${NC}"
    printf "%b\n" "  \`egskew\` ${BLUE}-- graphical emacsclient (opens new window)${NC}"
    echo ""
    echo "NOTE: Please exit this shell with Ctrl-D before doing './compose-dev down'."
    echo ""
}

# =============================================================================
# MAIN
# =============================================================================
main() {
    case "${1:-help}" in
        help|--help|-h) ;;
        *) preflight_checks || exit 1 ;;
    esac

    check_docker_compose

    case "${1:-help}" in
        up)
            shift
            _up_daemon=false
            _up_remaining=""
            for _up_arg in "$@"; do
                case "$_up_arg" in
                    --daemon|-d) _up_daemon=true ;;
                    --pull)      PULL_ALWAYS=1 ;;
                    *)           _up_remaining="${_up_remaining:+$_up_remaining }$_up_arg" ;;
                esac
            done
            # shellcheck disable=SC2086  (word-split intentional: service names)
            start_services $_up_remaining

            if [ "$_up_daemon" = "false" ]; then
                install_shell_functions
                show_skew_welcome
                exec "${SHELL:-sh}" -i
            fi
            ;;
        down)   stop_services ;;
        restart) shift; restart_services "$@" ;;
        stop)   shift; run_compose stop "$@" ;;
        logs)   shift; show_logs "$@" ;;
        status|ps) show_status ;;
        emacs)  connect_emacs ;;
        pull)   pull_images ;;
        clean)  clean_all ;;
        install-shell-functions) install_shell_functions ;;
        init)
            init_env
            ensure_env
            log_success "Environment initialized"
            ;;
        config) show_config ;;
        help|--help|-h) show_help ;;
        *)
            log_error "Unknown command: $1"
            printf "Use '%s help' for usage information\n" "$0"
            exit 1
            ;;
    esac
}

main "$@"

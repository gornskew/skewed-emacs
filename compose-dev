#!/usr/bin/env bash

# =============================================================================
# PREFLIGHT: environment sanity checks (bash version, docker)
# =============================================================================
preflight_checks() {
    local ok=true

    # --- Bash version ---
    if [ "${BASH_VERSINFO[0]}" -lt 4 ] 2>/dev/null; then
        echo ""
        echo "╔══════════════════════════════════════════════════════════════════╗"
        echo "║  ERROR: bash 4+ required (you have: ${BASH_VERSION:-unknown})          ║"
        echo "╠══════════════════════════════════════════════════════════════════╣"
        echo "║  macOS ships bash 3.2 and does not update it automatically.     ║"
        echo "║                                                                  ║"
        echo "║  Fix:                                                            ║"
        echo "║    1. Install Homebrew:  https://brew.sh                        ║"
        echo "║    2. brew install bash                                          ║"
        echo "║    3. Add to ~/.zprofile:                                        ║"
        echo "║         export PATH=\"/opt/homebrew/bin:\$PATH\"                  ║"
        echo "║       (Apple Silicon: /opt/homebrew  Intel Mac: /usr/local)     ║"
        echo "║    4. Open a new terminal and retry.                            ║"
        echo "║                                                                  ║"
        echo "║  See README.md section: macOS Prerequisites                     ║"
        echo "╚══════════════════════════════════════════════════════════════════╝"
        echo ""
        ok=false
    fi

    # --- Docker ---
    if ! command -v docker &>/dev/null; then
        echo ""
        echo "╔══════════════════════════════════════════════════════════════════╗"
        echo "║  ERROR: docker not found on PATH                                ║"
        echo "╠══════════════════════════════════════════════════════════════════╣"
        echo "║  Docker is required to run the Skewed Emacs stack.              ║"
        echo "║                                                                  ║"
        echo "║  Fix:                                                            ║"
        echo "║    • macOS / Windows:                                            ║"
        echo "║        Install Docker Desktop:                                   ║"
        echo "║        https://www.docker.com/products/docker-desktop/          ║"
        echo "║    • Linux:                                                      ║"
        echo "║        https://docs.docker.com/engine/install/                  ║"
        echo "║                                                                  ║"
        echo "║  After installing, open a new terminal and retry.              ║"
        echo "╚══════════════════════════════════════════════════════════════════╝"
        echo ""
        ok=false
    elif ! docker info &>/dev/null; then
        echo ""
        echo "╔══════════════════════════════════════════════════════════════════╗"
        echo "║  ERROR: docker is installed but not running / not accessible    ║"
        echo "╠══════════════════════════════════════════════════════════════════╣"
        echo "║  Fix:                                                            ║"
        echo "║    • macOS / Windows: start Docker Desktop and wait for it      ║"
        echo "║      to show the green 'Engine running' status, then retry.    ║"
        echo "║    • Linux: sudo systemctl start docker                         ║"
        echo "╚══════════════════════════════════════════════════════════════════╝"
        echo ""
        ok=false
    fi

    [ "$ok" = true ]
}

# Run preflight immediately on any non-trivial invocation
case "${1:-help}" in
    help|--help|-h) ;;   # skip preflight for pure help
    *) preflight_checks || exit 1 ;;
esac


cd "${0%/*}"

export DOCKER_CONFIG=~/.docker

SCRIPT_DIR="$(pwd)"
COMPOSE_FILE="${SCRIPT_DIR}/docker-compose.yml"


base=./docker-compose.yml; [[ -f $base ]] && c=("$base")

shopt -s nullglob
for f in ./*.yml; do
  n=${f##*/}; [[ $n = docker-compose.yml ]] && continue
  [[ $n = *"-dev-"* ]] && d+=("$f") || o+=("$f")
done

[[ ${#o[@]} -gt 0 ]] && c+=($(printf '%s\n' "${o[@]}"|sort))
[[ ${#d[@]} -gt 0 ]] && c+=($(printf '%s\n' "${d[@]}"|sort))

COMPOSE_FILES=("${c[@]}")


# Build the Docker Compose command with all .yml files
COMPOSE_FILES_ARGS=()
for file in "${COMPOSE_FILES[@]}"; do
    COMPOSE_FILES_ARGS+=("-f" "$file")
done

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color
# New / adjusted for distinction
CYAN='\033[0;36m'       # for base file (clear & distinct from info blue)
MAGENTA='\033[0;35m'    # for dev overlays (stands out as "custom/modifying")


# Helper functions
log_info() { printf "%b\n" "${BLUE}[INFO]${NC} $1"; }
log_success() { printf "%b\n" "${GREEN}[SUCCESS]${NC} $1"; }
log_warning() { printf "%b\n" "${YELLOW}[WARNING]${NC} $1"; }
log_error() { printf "%b\n" "${RED}[ERROR]${NC} $1"; }

# Check if docker compose is available
check_docker_compose() {
    if docker compose version &> /dev/null; then
        COMPOSE_CMD="docker compose"
    elif docker-compose version &> /dev/null; then
        COMPOSE_CMD="docker-compose"
    else
        log_error "Neither 'docker compose' nor 'docker-compose' is available"
        exit 1
    fi

    # Get basenames, sort them alphabetically
    mapfile -t sorted_basenames < <(printf '%s\n' "${COMPOSE_FILES[@]##*/}" | sort)


    log_info "Using: $COMPOSE_CMD"
    log_info "Compose files (application order - later files override earlier):"

    for full_path in "${COMPOSE_FILES[@]}"; do
        filename="${full_path##*/}"

        if [[ "$filename" == "docker-compose.yml" ]]; then
            # Base file - cyan or bold blue
            log_info "  - ${CYAN}${filename}${NC}  ${BLUE}(base)${NC}"

        elif [[ "$filename" == *"-dev-"* ]]; then
            # Dev overlays - magenta/yellow
            log_info "  - ${MAGENTA}${filename}${NC}  ${YELLOW}(dev overlay)${NC}"

        else
            # Regular service overlays - green
            log_info "  - ${GREEN}${filename}${NC}  ${GREEN}(added services)${NC}"
        fi
    done

    
}

# Initialize environment
init_env() {
    # Export environment variables for Docker Compose
    export HOME="${HOME}"
    PROJECTS_DIR="${PROJECTS_DIR:-${HOME}/projects}"
    export PROJECTS_DIR

    # Dynamically detect Docker group ID
    if [ -S "/var/run/docker.sock" ]; then
        export DOCKER_GROUP_ID=$(stat -c '%g' /var/run/docker.sock)
        log_info "Detected Docker group ID: $DOCKER_GROUP_ID"
    else
        export DOCKER_GROUP_ID=999
        log_warning "Docker socket not found, using default group ID: $DOCKER_GROUP_ID"
    fi

    # Ensure projects directory exists
    if [ ! -d "$PROJECTS_DIR" ]; then
        log_info "Creating projects directory: $PROJECTS_DIR"
        mkdir -p "$PROJECTS_DIR"
    fi
}

ensure_env() {
    ${SCRIPT_DIR}/generate-env.sh
}




# Show usage
show_help() {
    cat << EOF
Docker Compose Management for Skewed Emacs + Gendl Development Environment

USAGE:
    $0 <command> [options]

COMMANDS:
    up [service...]     Start services (default: all services)
    down               Stop and remove all services
    restart [service]  Restart service(s)
    stop [service]     Stop service(s) without removing
    logs [service]     Show logs for service(s)
    status             Show status of all services
    ps                 Show running containers
    emacs              Connect to Emacs via emacsclient
    pull               Pull missing images (use PULL_ALWAYS=1 to pull latest)
    clean              Remove containers, networks, and images
    init               Initialize environment (.env setup via generate-env.sh)
    install-shell-functions  Write eskew/egskew to ~/.config/skewed-emacs/shell-functions.sh and source from ~/.bashrc
    config             Show merged Docker Compose configuration

SERVICES:
    Services are defined in docker-compose.yml and any other .yml files
    in this directory (generated from services.sexp, the editable SSoT).

EXAMPLES:
    $0 up                    # Start all services
    $0 up --pull             # Start all services and pull latest images
    $0 up <service>          # Start only one service
    $0 up --pull <service>   # Start one service and pull latest image
    $0 logs <service>        # Show service logs
    PROJECTS_DIR=/path/to/projects $0 up   # Use a custom projects directory
    $0 emacs                 # Connect to Emacs interactively
    $0 config                # Show merged configuration

ENVIRONMENT:
    .env is generated by ./generate-env.sh; do not edit it directly.
    Set env vars before running ./compose-dev up or ./generate-env.sh.
    Additional .yml files in the current directory are automatically included.

    Key variables:
        PROJECTS_DIR           Projects directory to mount (default: ~/projects)

NETWORK:
    Services communicate via Docker network 'skewed-emacs-network'
    - From host: localhost:<host-port>
    - Inter-container: <service-hostname>:<container-port>

EOF
    
}

# Service management
start_services() {
    local services="$*"
    init_env
    ensure_env

    # Ensure AI TUI auth placeholder files exist on host
    # (Docker mounts create directories if files don't exist, which breaks the TUIs)

    
    for auth_file in \
        "${HOME}/.claude/.credentials.json" \
        "${HOME}/.gemini/google_accounts.json" \
        "${HOME}/.gemini/oauth_creds.json" \
        "${HOME}/.codex/auth.json"; do
        auth_file=$(eval echo "$auth_file")
        if [ ! -f "$auth_file" ]; then
            mkdir -p "$(dirname "$auth_file")"
            touch "$auth_file"
            log_info "Created placeholder: $auth_file"
        fi
    done

    pull_images

    log_info "Starting services: ${services:-all}"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" up -d $services

# Merge MCP configs for Claude/Gemini/Codex CLI tools (all formats)
    # Option B: Copy overlay files into container, merge there, copy results back
    log_info "Preparing MCP configurations (JSON + TOML)..."
    
    # Step 1: Copy any overlay MCP config files from host into container
    # These take precedence over same-named files in the container image
    for overlay_file in "${SCRIPT_DIR}/mcp/"*-mcp-windows.json "${SCRIPT_DIR}/mcp/"*-mcp-container.json "${SCRIPT_DIR}/mcp/"*-mcp.toml; do
        if [ -f "$overlay_file" ]; then
            log_info "Copying overlay: $(basename "$overlay_file")"
            $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" cp \
                "$overlay_file" \
                skewed-emacs:/home/emacs-user/skewed-emacs/mcp/ 2>/dev/null || true
        fi
    done

    # Step 1b: Copy any overlay services-generated files for dashboard discovery
    for overlay_file in "${SCRIPT_DIR}/dot-files/emacs.d/etc/"*-services-generated.el; do
        if [ -f "$overlay_file" ]; then
            log_info "Copying overlay: $(basename "$overlay_file")"
            $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" cp \
                "$overlay_file" \
                skewed-emacs:/home/emacs-user/skewed-emacs/dot-files/emacs.d/etc/ 2>/dev/null || true
        fi
    done
    
    # Step 2: Run the merge inside the container (retry loop for daemon startup)
    MCP_MERGE_SUCCESS=false
    for attempt in 1 2 3 4 5; do
        if $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" exec -T skewed-emacs emacsclient --eval \
            "(progn (setenv \"SKEWED_CLONE_PATH\" \"${SCRIPT_DIR}\")
                    (load-file \"/home/emacs-user/skewed-emacs/mcp/merge-mcp-configs.el\")
                    (skewed-merge-all-mcp-configs \"/home/emacs-user/skewed-emacs/mcp\"))" \
            > /dev/null 2>&1; then
            MCP_MERGE_SUCCESS=true
            break
        fi
        if [ $attempt -lt 5 ]; then
            log_info "Waiting for emacs daemon (attempt $attempt/5)..."
            sleep 2
        fi
    done
    
    # Step 3: Copy merged Windows config back to host clone directory
    if [ "$MCP_MERGE_SUCCESS" = true ]; then
        $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" cp \
            skewed-emacs:/tmp/merged-mcp-windows.json \
            "${SCRIPT_DIR}/mcp/claude_desktop_config.json" 2>/dev/null || true
        
        if [ -f "${SCRIPT_DIR}/mcp/claude_desktop_config.json" ]; then
            log_success "MCP configurations ready (container CLI, Windows, Codex)"
            log_info "Claude Desktop users: copy mcp/claude_desktop_config.json to %APPDATA%\\Claude\\"
        else
            log_success "MCP configurations ready (container CLI, Codex)"
        fi
    else
        log_warning "MCP config merge failed (emacsclient not ready yet?)"
    fi

}

stop_services() {
    log_info "Stopping all services"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" down
}

restart_services() {
    local services="$*"
    log_info "Restarting services: ${services:-all}"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" restart $services
    
}

show_logs() {
    local services="$*"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" logs -f $services
}

show_status() {
    log_info "Service status:"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" ps
}

connect_emacs() {
    log_info "Connecting to Emacs via emacsclient"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" exec skewed-emacs emacsclient -t
}

pull_images() {
    if [ -n "${NO_PULL}" ]; then
        log_info "Skipping pull (NO_PULL set)"
        return
    fi

    if [ -n "${PULL_ALWAYS}" ]; then
        log_info "Pulling latest images (PULL_ALWAYS set)"
        $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" pull
        return
    fi

    log_info "Pulling missing images only"

    local service_image_pairs
    service_image_pairs=$(
        $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" config | awk '
            $1 == "services:" { in_services=1; next }
            in_services && match($0, /^[[:space:]]{2}[A-Za-z0-9_-]+:$/) {
                service=$1; sub(":", "", service); next
            }
            in_services && $1 == "image:" { print service, $2 }
        '
    )

    local missing=()
    while read -r service image; do
        if [ -z "$service" ] || [ -z "$image" ]; then
            continue
        fi
        if docker image inspect "$image" > /dev/null 2>&1; then
            log_info "Image present locally, skipping pull: $service ($image)"
        else
            missing+=("$service")
        fi
    done <<< "$service_image_pairs"

    if [ ${#missing[@]} -eq 0 ]; then
        log_success "All images present locally; skipping pull"
        return
    fi

    log_info "Pulling missing services: ${missing[*]}"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" pull "${missing[@]}"
}

clean_all() {
    log_warning "This will remove containers, networks, and unused images (including pulled ones)"
    read -p "Are you sure? (y/N): " -n 1 -r
    printf "\n"
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        log_info "Cleaning up..."
        $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" down --rmi all --volumes --remove-orphans
        docker system prune -f
        log_success "Cleanup complete"
    else
        log_info "Cleanup cancelled"
    fi
}

show_config() {
    log_info "Showing merged Docker Compose configuration"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" config
}


# Inline shell functions for convenient Emacs access
eskew() {
    docker exec -it --detach-keys "ctrl-^" skewed-emacs emacsclient -t "$@"
}

egskew() {
    docker exec -it --detach-keys "ctrl-^" skewed-emacs emacsclient -c "$@" &
}


install_shell_functions() {
    local snippet_dir="${HOME}/.config/skewed-emacs"
    local snippet_file="${snippet_dir}/shell-functions.sh"
    local bashrc="${HOME}/.bashrc"
    local source_line="[ -f \"${snippet_file}\" ] && source \"${snippet_file}\""

    mkdir -p "${snippet_dir}"

    cat > "${snippet_file}" << 'SNIPPET'
# Skewed Emacs shell helpers - auto-generated by compose-dev
# These work in any shell as long as the skewed-emacs container is running.

eskew() {
    docker exec -it --detach-keys "ctrl-^" skewed-emacs emacsclient -t "$@"
}

egskew() {
    docker exec -it --detach-keys "ctrl-^" skewed-emacs emacsclient -c "$@" &
}
SNIPPET

    # Idempotently add source line to ~/.bashrc
    if ! grep -qF "skewed-emacs/shell-functions.sh" "${bashrc}" 2>/dev/null; then
        printf '\n# Skewed Emacs shell helpers\n%s\n' "${source_line}" >> "${bashrc}"
        log_success "Added skewed-emacs shell helpers to ${bashrc}"
    else
        log_info "Shell helpers already in ${bashrc} (no change needed)"
    fi

    log_success "Shell functions written to ${snippet_file}"
    log_info "Run \`source ~/.bashrc\` or open a new shell to activate eskew/egskew"
}

show_skew_welcome() {
    echo "" 
    echo "Services are Up."
    echo ""
    echo "Shell Commands for the 🦖 Skewed Emacs Stack 🦖"
    echo ""
    printf "%b\n" "\`eskew\` ${BLUE}for a terminal emacsclient, or${NC}"
    printf "%b\n\n" "\`egskew\` ${BLUE}for a graphical one.${NC}"
    echo ""
    echo "NOTE: Please exit this shell with Ctrl-D before doing './compose-dev down'."
    echo "" 
}


# Main command dispatcher
main() {
    check_docker_compose
    
    case "${1:-help}" in
        up)
            shift
            daemon_mode=false
            remaining_args=()
            for arg in "$@"; do
                case "$arg" in
                    --daemon|-d)
                        daemon_mode=true
                        ;;
                    --pull)
                        PULL_ALWAYS=1
                        ;;
                    *)
                        remaining_args+=("$arg")
                        ;;
                esac
            done
            start_services "${remaining_args[@]}"
            
            if [ "$daemon_mode" = false ]; then
                install_shell_functions
                show_skew_welcome
                exec bash -i
            fi
            ;;
        down)
            stop_services
            ;;
        restart)
            shift
            restart_services "$@"
            ;;
        stop)
            shift
            $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" stop "$@"
            ;;
        logs)
            shift
            show_logs "$@"
            ;;
        status|ps)
            show_status
            ;;
        emacs)
            connect_emacs
            ;;
        pull)
            pull_images
            ;;
        clean)
            clean_all
            ;;
        install-shell-functions)
            install_shell_functions
            ;;
        init)
            init_env
            ensure_env
            log_success "Environment initialized"
            ;;
        config)
            show_config
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            log_error "Unknown command: $1"
            printf "Use '%s help' for usage information\n" "$0"
            exit 1
            ;;
    esac
}

# Run main function
main "$@"

#!/bin/bash
# Docker Compose Management Script for Skewed Emacs + Gendl Development Environment
# Dr. Frankenstein'd together from existing run scripts with enhanced compose orchestration

set -e

cd "$(dirname "$0")"

export DOCKER_CONFIG=~/.docker

SCRIPT_DIR="$(pwd)"
COMPOSE_FILE="${SCRIPT_DIR}/docker-compose.yml"

# Find all .yml files in the current directory, excluding docker-compose.yml
COMPOSE_FILES=("$COMPOSE_FILE")
while IFS= read -r file; do
    if [[ "$file" != "$COMPOSE_FILE" ]]; then
        COMPOSE_FILES+=("$file")
    fi
done < <(find "$SCRIPT_DIR" -maxdepth 1 -type f -name "*.yml")

# Build the Docker Compose command with all .yml files
COMPOSE_FILES_ARGS=()
for file in "${COMPOSE_FILES[@]}"; do
    COMPOSE_FILES_ARGS+=("-f" "$file")
done

if [ "$1" = "up" ]; then
    ${SCRIPT_DIR}/generate-env.sh
fi

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Helper functions
log_info() { printf "%b\n" "${BLUE}[INFO]${NC} $1"; }
log_success() { printf "%b\n" "${GREEN}[SUCCESS]${NC} $1"; }
log_warning() { printf "%b\n" "${YELLOW}[WARNING]${NC} $1"; }
log_error() { printf "%b\n" "${RED}[ERROR]${NC} $1"; }

# Check if docker compose is available
check_docker_compose() {
    if ! command -v docker &> /dev/null; then
        log_error "Docker is not installed or not in PATH"
        exit 1
    fi

    if docker compose version &> /dev/null; then
        COMPOSE_CMD="docker compose"
    elif docker-compose version &> /dev/null; then
        COMPOSE_CMD="docker-compose"
    else
        log_error "Neither 'docker compose' nor 'docker-compose' is available"
        exit 1
    fi

    log_info "Using: $COMPOSE_CMD"
    log_info "Compose files: ${COMPOSE_FILES[*]}"
}

# Initialize environment
init_env() {
    # Export environment variables for Docker Compose
    export HOME="${HOME}"
    export PROJECTS_DIR="${HOME}/projects"

    # Dynamically detect Docker group ID
    if [ -S "/var/run/docker.sock" ]; then
        export DOCKER_GROUP_ID=$(stat -c '%g' /var/run/docker.sock)
        log_info "Detected Docker group ID: $DOCKER_GROUP_ID"
    else
        export DOCKER_GROUP_ID=999
        log_warning "Docker socket not found, using default group ID: $DOCKER_GROUP_ID"
    fi

    if [ ! -f "${SCRIPT_DIR}/.env" ] && [ -f "${SCRIPT_DIR}/.env.example" ]; then
        log_info "Creating .env from .env.example"
        cp "${SCRIPT_DIR}/.env.example" "${SCRIPT_DIR}/.env"
        log_success "Created .env file - please customize as needed"
    fi

    # Ensure projects directory exists
    PROJECTS_DIR="${PROJECTS_DIR:-${HOME}/projects}"
    if [ ! -d "$PROJECTS_DIR" ]; then
        log_info "Creating projects directory: $PROJECTS_DIR"
        mkdir -p "$PROJECTS_DIR"
    fi
}




# Show usage
show_help() {
    cat << EOF
Docker Compose Management for Skewed Emacs + Gendl Development Environment

USAGE:
    $0 <command> [options]

COMMANDS:
    up [service...]     Start services (default: all services)
    down               Stop and remove all services
    restart [service]  Restart service(s)
    stop [service]     Stop service(s) without removing
    logs [service]     Show logs for service(s)
    status             Show status of all services
    ps                 Show running containers
    shell <service>    Open shell in service container
    emacs              Connect to Emacs via emacsclient
    slime              Show SLIME connection info
    test               Test HTTP APIs
    pull               Pull latest images
    clean              Remove containers, networks, and images
    init               Initialize environment (.env setup)
    config             Show merged Docker Compose configuration

SERVICES:
    skewed-emacs       Skewed Emacs container (HTTP API on port 7081)
    gendl              Gendl container (HTTP API on port 9081, SWANK on port 4201)
    genworks-gdl       Genworks GDL container (HTTP API on port 9089, SWANK on port 4209) [optional]

EXAMPLES:
    $0 up                    # Start all services
    $0 up skewed-emacs       # Start only skewed-emacs
    $0 logs gendl            # Show gendl logs
    $0 shell skewed-emacs    # Open shell in skewed-emacs container
    $0 emacs                 # Connect to Emacs interactively
    $0 test                  # Test HTTP APIs
    $0 slime                 # Show SLIME connection instructions
    $0 config                # Show merged configuration

ENVIRONMENT:
    Customize settings by editing .env file (created from .env.example)
    Additional .yml files in the current directory are automatically included.

    Key variables:
        PROJECTS_DIR           Projects directory to mount (default: ~/projects)
        EMACS_HTTP_HOST_PORT   Emacs API port (default: 7081)
        GENDL_HTTP_HOST_PORT   Gendl API port (default: 9081)
        GENDL_SWANK_HOST_PORT  Gendl SWANK port (default: 4201)
        GDL_HTTP_HOST_PORT     Genworks GDL API port (default: 9089)
        GDL_SWANK_HOST_PORT    Genworks GDL SWANK port (default: 4209)

NETWORK:
    Services communicate via Docker network 'skewed-emacs-network'
    - From host: localhost:<host-port>
    - Inter-container: <service-hostname>:<container-port>

EOF
    
}

# Service management
start_services() {
    local services="$*"
    init_env

    if [ -z "${NO_PULL}" ]; then
        pull_images
    fi

    log_info "Starting services: ${services:-all}"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" up -d $services

# Merge MCP configs for Claude/Gemini/Codex CLI tools (all formats)
    # Option B: Copy overlay files into container, merge there, copy results back
    log_info "Preparing MCP configurations (JSON + TOML)..."
    
    # Step 1: Copy any overlay MCP config files from host into container
    # These take precedence over same-named files in the container image
    for overlay_file in "${SCRIPT_DIR}/mcp/"*-mcp-windows.json "${SCRIPT_DIR}/mcp/"*-mcp-container.json "${SCRIPT_DIR}/mcp/"*-mcp.toml; do
        if [ -f "$overlay_file" ]; then
            log_info "Copying overlay: $(basename "$overlay_file")"
            $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" cp \
                "$overlay_file" \
                skewed-emacs:/home/emacs-user/skewed-emacs/mcp/ 2>/dev/null || true
        fi
    done

    # Step 1b: Copy any overlay services-generated files for dashboard discovery
    for overlay_file in "${SCRIPT_DIR}/dot-files/emacs.d/etc/"*-services-generated.el; do
        if [ -f "$overlay_file" ]; then
            log_info "Copying overlay: $(basename "$overlay_file")"
            $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" cp \
                "$overlay_file" \
                skewed-emacs:/home/emacs-user/skewed-emacs/dot-files/emacs.d/etc/ 2>/dev/null || true
        fi
    done
    
    # Step 2: Run the merge inside the container (retry loop for daemon startup)
    MCP_MERGE_SUCCESS=false
    for attempt in 1 2 3 4 5; do
        if $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" exec -T skewed-emacs emacsclient --eval \
            "(progn (setenv \"SKEWED_CLONE_PATH\" \"${SCRIPT_DIR}\")
                    (load-file \"/home/emacs-user/skewed-emacs/mcp/merge-mcp-configs.el\")
                    (skewed-merge-all-mcp-configs \"/home/emacs-user/skewed-emacs/mcp\"))" \
            > /dev/null 2>&1; then
            MCP_MERGE_SUCCESS=true
            break
        fi
        if [ $attempt -lt 5 ]; then
            log_info "Waiting for emacs daemon (attempt $attempt/5)..."
            sleep 2
        fi
    done
    
    # Step 3: Copy merged Windows config back to host clone directory
    if [ "$MCP_MERGE_SUCCESS" = true ]; then
        $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" cp \
            skewed-emacs:/tmp/merged-mcp-windows.json \
            "${SCRIPT_DIR}/mcp/claude_desktop_config.json" 2>/dev/null || true
        
        if [ -f "${SCRIPT_DIR}/mcp/claude_desktop_config.json" ]; then
            log_success "MCP configurations ready (container CLI, Windows, Codex)"
            log_info "Claude Desktop users: copy mcp/claude_desktop_config.json to %APPDATA%\\Claude\\"
        else
            log_success "MCP configurations ready (container CLI, Codex)"
        fi
    else
        log_warning "MCP config merge failed (emacsclient not ready yet?)"
    fi

}

stop_services() {
    log_info "Stopping all services"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" down
}

restart_services() {
    local services="$*"
    log_info "Restarting services: ${services:-all}"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" restart $services
    
}

show_logs() {
    local services="$*"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" logs -f $services
}

show_status() {
    log_info "Service status:"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" ps
}

open_shell() {
    local service="$1"
    if [ -z "$service" ]; then
        log_error "Please specify a service: skewed-emacs, gendl-ccl, or gendl-sbcl"
        exit 1
    fi

    log_info "Opening shell in $service container"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" exec "$service" /bin/bash
}

connect_emacs() {
    log_info "Connecting to Emacs via emacsclient"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" exec skewed-emacs emacsclient -t
}

test_apis() {
    log_info "Testing HTTP APIs and SWANK ports (host-facing)..."

    local timeout_sec=10   # generous but still fast feedback

    # Helper to test HTTP /lisply/ping-lisp endpoint
    test_http() {
        local name="$1"
        local port="${2:-7081}"
        printf "%-30s (port %s): " "$name" "$port"
        if curl -s -f --connect-timeout 5 "http://localhost:${port}/lisply/ping-lisp" > /dev/null 2>&1; then
            printf "%b\n" "${GREEN}OK${NC}"
        else
            printf "%b\n" "${RED}FAILED${NC}"
        fi
    }

    # Helper to test SWANK with nc -zv (verbose + zero-io mode)
    test_swank() {
        local name="$1"
        local port="$2"
        printf "%-30s (port %s): " "$name" "$port"
        if nc -zv localhost "$port" > /dev/null 2>&1; then
            printf "%b\n" "${GREEN}OK${NC}"
        else
            printf "%b\n" "${RED}FAILED${NC}"
        fi
    }

    # 1. skewed-emacs (only HTTP)
    test_http "Skewed Emacs API" "${EMACS_HTTP_HOST_PORT:-7081}"

    # 2. Gendl CCL
    test_http "Gendl CCL API"      "${GENDL_HTTP_HOST_PORT:-9081}"
    test_swank "Gendl CCL SWANK"   "${GENDL_SWANK_HOST_PORT:-4201}"

    # 3. Gendl SBCL
    test_http "Gendl SBCL API"     "${GENDL_SBCL_HTTP_HOST_PORT:-9091}"
    test_swank "Gendl SBCL SWANK"  "${GENDL_SBCL_SWANK_HOST_PORT:-4211}"

    # 4. Genworks GDL non-SMP (only if container exists)
    if $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" ps -q genworks-gdl-non-smp >/dev/null 2>&1; then
        test_http "Genworks GDL non-SMP API"  "${GDL_NON_SMP_HTTP_HOST_PORT:-9089}"
        test_swank "Genworks GDL non-SMP SWANK" "${GDL_NON_SMP_SWANK_HOST_PORT:-4209}"
    fi

    # 5. Genworks GDL SMP (only if container exists)
    if $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" ps -q genworks-gdl-smp >/dev/null 2>&1; then
        test_http "Genworks GDL SMP API"      "${GDL_SMP_HTTP_HOST_PORT:-9099}"
        test_swank "Genworks GDL SMP SWANK"   "${GDL_SMP_SWANK_HOST_PORT:-4219}"
    fi
}

show_slime_info() {
    cat << EOF

${BLUE}SLIME Connection Information:${NC}

${GREEN}From Host Emacs (Gendl):${NC}
    M-x slime-connect RET localhost RET ${GENDL_SWANK_HOST_PORT:-4201} RET

${GREEN}From Host Emacs (Genworks GDL, if running):${NC}
    M-x slime-connect RET localhost RET ${GDL_SWANK_HOST_PORT:-4209} RET

${GREEN}From Emacs Container (Gendl):${NC}
    M-x slime-connect RET gendl RET 4200 RET

${GREEN}From Emacs Container (Genworks GDL, if running):${NC}
    M-x slime-connect RET genworks-gdl RET 4208 RET

${GREEN}Connection Test:${NC}
    $0 test

${GREEN}Alternative Access:${NC}
    # Direct container shell access
    $0 shell gendl
    $0 shell genworks-gdl

    # Emacs interactive access
    $0 emacs

EOF
}


pull_images() {
    log_info "Pulling latest images"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" pull
}

clean_all() {
    log_warning "This will remove containers, networks, and unused images"
    read -p "Are you sure? (y/N): " -n 1 -r
    printf "\n"
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        log_info "Cleaning up..."
        $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" down --rmi local --volumes --remove-orphans
        docker system prune -f
        log_success "Cleanup complete"
    else
        log_info "Cleanup cancelled"
    fi
}

show_config() {
    log_info "Showing merged Docker Compose configuration"
    $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" config
}


# Inline shell functions for convenient Emacs access
eskew() {
    docker exec -it --detach-keys "ctrl-^" skewed-emacs emacsclient -t "$@"
}

egskew() {
    docker exec -it --detach-keys "ctrl-^" skewed-emacs emacsclient -c "$@" &
}

# Optional: print welcome message when the functions are defined
# (this will show every time the script is sourced or run, but only matters for 'up')
show_skew_welcome() {
    echo "" 
    echo "Services are Up."
    echo ""
    echo "Shell Commands for the 🦖 Skewed Emacs Stack 🦖"
    echo ""
    printf "%b\n" "\`eskew\` ${BLUE}for a terminal emacsclient, or${NC}"
    printf "%b\n\n" "\`egskew\` ${BLUE}for a graphical one.${NC}"
    echo ""
    echo "NOTE: Please exit this shell with Ctrl-D before doing './compose-dev down'."
    echo "" 
}


# Main command dispatcher
main() {
    check_docker_compose
    
    case "${1:-help}" in
        up)
            shift
            daemon_mode=false
            remaining_args=()
            for arg in "$@"; do
                case "$arg" in
                    --daemon|-d)
                        daemon_mode=true
                        ;;
                    *)
                        remaining_args+=("$arg")
                        ;;
                esac
            done
            start_services "${remaining_args[@]}"
            
            if [ "$daemon_mode" = false ]; then
                export -f eskew
                export -f egskew
                show_skew_welcome
                exec bash -i
            fi
            ;;
        down)
            stop_services
            ;;
        restart)
            shift
            restart_services "$@"
            ;;
        stop)
            shift
            $COMPOSE_CMD "${COMPOSE_FILES_ARGS[@]}" stop "$@"
            ;;
        logs)
            shift
            show_logs "$@"
            ;;
        status|ps)
            show_status
            ;;
        shell)
            open_shell "$2"
            ;;
        emacs)
            connect_emacs
            ;;
        slime)
            show_slime_info
            ;;
        test)
            test_apis
            ;;
        pull)
            pull_images
            ;;
        clean)
            clean_all
            ;;
        init)
            init_env
            log_success "Environment initialized"
            ;;
        config)
            show_config
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            log_error "Unknown command: $1"
            printf "Use '%s help' for usage information\n" "$0"
            exit 1
            ;;
    esac
}

# Run main function
main "$@"

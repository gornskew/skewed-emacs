#!/bin/bash
#
# generate-configs.sh - Generate all config files from services.json (Single Source of Truth)
#
# This script reads services.json (and optional private overlays) and generates:
#   1. docker-compose.yml
#   2. mcp-config.json (for Claude Code / JSON-based MCP clients)
#   3. mcp-config.toml (for TOML-based MCP clients)
#   4. services-discovery.el (for Emacs dashboard)
#
# Usage:
#   ./generate-configs.sh                    # Generate from services.json only
#   ./generate-configs.sh --with-private     # Include services-private.json overlay
#

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVICES_FILE="$SCRIPT_DIR/services.json"
PRIVATE_FILE="$SCRIPT_DIR/services-private.json"

# Check for node/jq
if ! command -v node &> /dev/null; then
    echo "Error: node is required but not installed."
    exit 1
fi

# The actual generation is done by a Node.js script for easier JSON manipulation
node "$SCRIPT_DIR/scripts/generate-from-services.js" "$@"

#!/bin/sh
# setup — POSIX sh; works with bash, dash, zsh, and macOS /bin/sh

# =============================================================================
# PORTABLE REALPATH
# realpath(1) is not available on macOS or older Linux without coreutils.
# readlink -f also absent on macOS BSD readlink.
# This pure-shell fallback works everywhere.
# =============================================================================
if ! command -v realpath > /dev/null 2>&1; then
    realpath() {
        # Resolve to absolute path without requiring the target to exist.
        # If the path exists, cd into its directory and print; else compose manually.
        case "$1" in
            /*) printf '%s\n' "$1" ;;
            *)  printf '%s/%s\n' "$(pwd)" "$1" ;;
        esac
    }
fi

# =============================================================================
# HELP
# =============================================================================
show_help() {
    echo ""
    echo "Skewed Emacs Config Setup"
    echo "========================="
    echo "Sets up your home directory with symlinks to dot-files in this repo."
    echo ""
    echo "Usage: ./setup [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  --help, -h                    Show this help message and exit"
    echo "  --dry-run                     Show what would happen without making changes"
    echo "  --force, -f                   Force replacement of existing valid symlinks"
    echo ""
    echo "  --shadow-suffix=NAME          Create symlinks with a \"-NAME\" suffix"
    echo "  --shadow-suffix NAME          (e.g., --shadow-suffix=test -> ~/.emacs.d-test)"
    echo ""
    echo "  --scrub-shadow-suffix=NAME    Remove all symlinks with the \"-NAME\" suffix"
    echo "  --scrub-shadow-suffix NAME"
    echo ""
    echo "  --scrub-shadow-suffix=\"\"     Remove default symlinks (no suffix)"
    echo ""
    echo "The script detects and replaces broken symlinks, backs up existing"
    echo "dotfiles with a \"-pre-skewed-emacs\" suffix, and skips tilde backup files."
    echo ""
    echo "Examples:"
    echo "  ./setup --dry-run"
    echo "  ./setup"
    echo "  ./setup --shadow-suffix=shadow"
    echo "  ./setup --scrub-shadow-suffix=test"
    echo "  ./setup --scrub-shadow-suffix=\"\" --shadow-suffix=work"
    echo "  ./setup --force"
    echo ""
    echo "Warning: Existing ~/.emacs.d and dotfiles will be backed up, not deleted."
    echo "Run with --dry-run first to preview."
}

# =============================================================================
# ARGUMENT PARSING
# =============================================================================
shadow_suffix=""
shadow_suffix_set=false   # distinguish "not passed" from "passed as empty"
dry_run=false
force=false
scrub_suffix=""
scrub_suffix_set=false

# Check for help first
for _arg in "$@"; do
    case "$_arg" in
        --help|-help|-h) show_help; exit 0 ;;
    esac
done

# Full parse — two-pass: handle both "--opt=val" and "--opt val" forms
while [ $# -gt 0 ]; do
    _arg="$1"
    case "$_arg" in
        --shadow-suffix=*|-shadow-suffix=*)
            _val="${_arg#*=}"
            shadow_suffix_set=true
            [ -n "$_val" ] && shadow_suffix="-${_val}" || shadow_suffix=""
            ;;
        --shadow-suffix|-shadow-suffix)
            shadow_suffix_set=true
            shift
            [ -n "$1" ] && shadow_suffix="-${1}" || shadow_suffix=""
            ;;
        --scrub-shadow-suffix=*|-scrub-shadow-suffix=*)
            _val="${_arg#*=}"
            scrub_suffix_set=true
            [ -n "$_val" ] && scrub_suffix="-${_val}" || scrub_suffix=""
            ;;
        --scrub-shadow-suffix|-scrub-shadow-suffix)
            scrub_suffix_set=true
            shift
            [ -n "$1" ] && scrub_suffix="-${1}" || scrub_suffix=""
            ;;
        --dry-run|-dry-run) dry_run=true ;;
        --force|-force|-f)  force=true ;;
    esac
    shift
done

# =============================================================================
# REPO / DOT-FILES LOCATION
# =============================================================================
SCRIPT_PATH="$(realpath "$0")"
REPO_DIR="$(dirname "$SCRIPT_PATH")"
dot_files="$REPO_DIR/dot-files/"

echo ""
echo "Skewed Emacs Config Setup"
echo "========================="
echo "Sets up your home directory with symlinks to dot-files in this repo."
echo ""
echo "Using repository at: $REPO_DIR"

if [ "$dry_run" = "true" ]; then
    echo "Running in DRY RUN mode - no changes will be made"
fi

if [ ! -d "$dot_files" ]; then
    echo >&2 "ERROR: Could not find dot-files directory at $dot_files"
    echo >&2 "Please run this script from the root of the skewed-emacs repository."
    exit 1
fi

# =============================================================================
# PREREQUISITES CHECK
# =============================================================================
for _prereq in emacs git; do
    if ! command -v "$_prereq" > /dev/null 2>&1; then
        echo >&2 "WARNING: '$_prereq' not found. Your environment may not function correctly."
    fi
done

if command -v node > /dev/null 2>&1; then
    _node_ver="$(node --version | sed 's/v//' | cut -d. -f1)"
    if [ "$_node_ver" -lt 22 ] 2>/dev/null; then
        echo >&2 "WARNING: Node.js $_node_ver detected; version 22+ recommended for AI integrations."
    fi
else
    echo >&2 "WARNING: Node.js not found; version 22+ required for AI integrations."
fi

if command -v emacs > /dev/null 2>&1; then
    _emacs_ver="$(emacs --version 2>/dev/null | sed -n '1p' | awk '{print $3}' | cut -d. -f1)"
    if [ "$_emacs_ver" -lt 29 ] 2>/dev/null; then
        echo >&2 "WARNING: Emacs $_emacs_ver detected; version 29+ recommended."
    fi
fi

echo ""
# =============================================================================
# SCRUB MODE
# =============================================================================
if [ "$scrub_suffix_set" = "true" ]; then
    echo "Running in SCRUB MODE - removing symlinks with suffix '${scrub_suffix}'"

    _found_files=false

    if [ -z "$scrub_suffix" ]; then
        # Empty suffix: only remove symlinks that point into our dot-files dir
        for _nf in "${dot_files}"*; do
            _nf="$(basename "$_nf")"
            case "$_nf" in *~) continue ;; esac
            _dp="$HOME/.${_nf}"
            if [ -h "$_dp" ]; then
                _tgt="$(readlink "$_dp")"
                case "$_tgt" in
                    *"$REPO_DIR/dot-files/"*)
                        _found_files=true
                        if [ "$dry_run" = "true" ]; then
                            echo "[DRY RUN] Would remove $_dp"
                        else
                            echo "Removing $_dp"
                            rm "$_dp"
                        fi
                        ;;
                esac
            fi
        done
    else
        # Non-empty suffix: iterate files in dot-files dir, build suffixed target names
        for _nf in "${dot_files}"*; do
            _nf="$(basename "$_nf")"
            case "$_nf" in *~) continue ;; esac
            _dp="$HOME/.${_nf}${scrub_suffix}"
            if [ -h "$_dp" ]; then
                _found_files=true
                if [ "$dry_run" = "true" ]; then
                    echo "[DRY RUN] Would remove $_dp"
                else
                    echo "Removing $_dp"
                    rm "$_dp"
                fi
            else
                [ -e "$_dp" ] && echo "Skipping $_dp (not a symlink)"
            fi
        done
    fi

    if [ "$_found_files" = "false" ]; then
        echo "No dotfiles with suffix '${scrub_suffix}' found."
    fi

    if [ "$dry_run" = "true" ]; then
        echo ""
        echo "DRY RUN scrubbing complete. No changes were made."
        echo "Run without --dry-run to apply changes."
    else
        echo ""
        echo "Scrubbing complete."
    fi

    echo ""
    # If no shadow install also requested, we're done
    [ "$shadow_suffix_set" = "false" ] && exit 0
    echo "Continuing with installation..."
fi

# Report mode
if [ -n "$shadow_suffix" ]; then
    echo "Running in SHADOW MODE - symlinks will use suffix '${shadow_suffix}'"
    echo "e.g. ~/.emacs.d${shadow_suffix} instead of ~/.emacs.d"
fi

# Safety note for same-suffix scrub+install
same_suffix_op=false
if [ "$scrub_suffix_set" = "true" ] && [ "$shadow_suffix_set" = "true" ] && \
   [ "$scrub_suffix" = "$shadow_suffix" ] && [ -n "$scrub_suffix" ]; then
    same_suffix_op=true
    echo "Note: scrub and install use the same suffix '${scrub_suffix}' — old links removed before new ones created."
fi

# =============================================================================
# MAIN INSTALL LOOP
# =============================================================================
for _nf in "${dot_files}"*; do
    _nf="$(basename "$_nf")"

    # Skip tilde backup files
    case "$_nf" in
        *~) echo "Skipping backup file $_nf"; continue ;;
    esac

    echo "Processing $_nf"

    _target_file=".${_nf}${shadow_suffix}"
    _target_path="$HOME/${_target_file}"
    _source_path="${dot_files}${_nf}"

    # Resolve both paths for comparison
    _source_real="$(realpath "$_source_path" 2>/dev/null)"

    # --- Already correctly linked? ---
    if [ -h "$_target_path" ]; then
        _existing_real="$(realpath "$(readlink "$_target_path")" 2>/dev/null)"
        if [ "$_existing_real" = "$_source_real" ]; then
            if [ "$same_suffix_op" = "true" ]; then
                # scrub already removed it; should not reach here, but handle gracefully
                :
            elif [ "$force" = "true" ]; then
                _bak="${_target_file}-pre-skewed-emacs-$(date +%Y%m%d-%H%M%S)"
                if [ "$dry_run" = "true" ]; then
                    echo "[DRY RUN] Would rename ~/${_target_file} -> ~/${_bak} and relink"
                else
                    echo "Force: renaming ~/${_target_file} -> ~/${_bak}"
                    mv "$_target_path" "$HOME/${_bak}"
                    ln -s "$_source_path" "$_target_path"
                    echo "Created symlink ~/${_target_file} -> $_source_path"
                fi
            else
                echo "~/${_target_file} already linked correctly — skipping."
            fi
            echo ""
            continue
        fi
    fi

    # --- Handle existing file / wrong-target symlink ---
    if [ -e "$_target_path" ] || [ -h "$_target_path" ]; then
        if [ "$force" = "true" ]; then
            _bak="${_target_file}-pre-skewed-emacs-$(date +%Y%m%d-%H%M%S)"
            if [ "$dry_run" = "true" ]; then
                echo "[DRY RUN] Would move ~/${_target_file} -> ~/${_bak} and relink"
            else
                echo "Force: moving ~/${_target_file} -> ~/${_bak}"
                mv "$_target_path" "$HOME/${_bak}"
            fi
        elif [ -h "$_target_path" ]; then
            # Wrong-target or broken symlink — back it up
            _old_tgt="$(readlink "$_target_path")"
            _status="wrong target"
            [ ! -e "$_old_tgt" ] && _status="broken"
            _bak="${_target_file}-pre-skewed-emacs"
            if [ "$dry_run" = "true" ]; then
                echo "[DRY RUN] Would move ~/${_target_file} (${_status}, -> ${_old_tgt}) -> ~/${_bak}"
            else
                echo "Moving ~/${_target_file} (${_status}) -> ~/${_bak}"
                rm -f "$HOME/${_bak}"
                mv "$_target_path" "$HOME/${_bak}"
            fi
        else
            # Regular file/dir — don't touch without --force
            echo "~/${_target_file} exists and is not a symlink. Use --force to replace."
            echo ""
            continue
        fi
    fi

    # --- Create the symlink ---
    if [ ! -e "$_target_path" ]; then
        if [ "$dry_run" = "true" ]; then
            echo "[DRY RUN] Would create symlink ~/${_target_file} -> $_source_path"
        else
            ln -s "$_source_path" "$_target_path"
            echo "Created symlink ~/${_target_file} -> $_source_path"
        fi
    fi

    echo ""
done

# =============================================================================
# SUMMARY
# =============================================================================
if [ "$dry_run" = "true" ]; then
    echo ""
    echo "DRY RUN complete. No changes were made."
    echo "Run without --dry-run to apply changes."
else
    echo ""
    echo "Setup complete! Configuration files linked from $REPO_DIR"
    echo ""
    echo "Next steps:"
    if [ -n "$shadow_suffix" ]; then
        echo "  Shadow installation mode:"
        echo "    emacs -q --load \"~/.emacs.d${shadow_suffix}/init.el\""
        echo "    . ~/.bash_profile${shadow_suffix}"
    else
        echo "  Standard installation mode:"
        echo "    killall -9 emacs emacs-gtk   # restart any running daemon"
        echo "    . ~/.bash_profile            # or open a new terminal"
    fi
fi

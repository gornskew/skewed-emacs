#!/bin/bash
#
# MCP exec wrapper - starts compose stack on demand if needed,
# then execs into the container to run the MCP wrapper.
#
# CRITICAL: This script must not output ANYTHING to stdout except
# the MCP protocol messages from the final exec. Any stray output
# will corrupt the MCP stdio protocol and cause the client to fail.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_DIR="${SCRIPT_DIR}/.."
SERVICE_NAME="skewed-emacs"
LOG_FILE="/tmp/mcp-exec.log"
LOCK_DIR="/tmp/mcp-exec.lock"
LOCK_PID_FILE="${LOCK_DIR}/pid"
STARTER_FILE="/tmp/mcp-compose-starter"
MAX_WAIT_SECONDS=90

# Track if this instance started compose and holds the lock
I_STARTED_COMPOSE=false
I_HOLD_LOCK=false

# All logging goes to file and stderr, NEVER stdout
log() {
    echo "[$(date -Iseconds)] [$$] $1" >> "$LOG_FILE"
    echo "[$(date -Iseconds)] [$$] $1" >&2
}

# Run docker compose commands in the compose directory
compose() {
    (cd "$COMPOSE_DIR" && docker compose "$@")
}

# Check if service is running using docker compose
is_service_running() {
    local status
    status=$(compose ps --format '{{.State}}' "$SERVICE_NAME" 2>/dev/null)
    [ "$status" = "running" ]
}

# Get health status using docker compose
get_health_status() {
    compose ps --format '{{.Health}}' "$SERVICE_NAME" 2>/dev/null
}

# Check if a lock is stale (owner process no longer exists)
is_lock_stale() {
    if [ -f "$LOCK_PID_FILE" ]; then
        local lock_pid
        lock_pid=$(cat "$LOCK_PID_FILE" 2>/dev/null)
        if [ -n "$lock_pid" ] && ! kill -0 "$lock_pid" 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

# Acquire lock with timeout - prevents multiple instances from racing
acquire_lock() {
    local waited=0
    
    if [ -d "$LOCK_DIR" ] && is_lock_stale; then
        log "Removing stale lock (owner process no longer exists)"
        rm -rf "$LOCK_DIR"
    fi
    
    while ! mkdir "$LOCK_DIR" 2>/dev/null; do
        if is_lock_stale; then
            log "Removing stale lock during wait"
            rm -rf "$LOCK_DIR"
            continue
        fi
        
        if [ $waited -ge 30 ]; then
            log "WARNING: Timeout waiting for lock, proceeding anyway"
            return 1
        fi
        sleep 1
        waited=$((waited + 1))
        if [ $((waited % 5)) -eq 0 ]; then
            log "Waiting for lock... ($waited/30)"
        fi
    done
    
    echo $$ > "$LOCK_PID_FILE"
    I_HOLD_LOCK=true
    return 0
}

release_lock() {
    if [ "$I_HOLD_LOCK" = true ]; then
        rm -rf "$LOCK_DIR"
        I_HOLD_LOCK=false
        log "Lock released"
    fi
}

# Wait for service to be healthy using docker compose
wait_for_healthy() {
    local waited=0

    log "Waiting for service ${SERVICE_NAME} to be healthy..."

    while true; do
        local health_status
        health_status=$(get_health_status)

        case "$health_status" in
            healthy)
                log "Service ${SERVICE_NAME} is healthy"
                return 0
                ;;
            unhealthy)
                log "WARNING: Service ${SERVICE_NAME} is unhealthy, proceeding anyway..."
                return 1
                ;;
            starting|"")
                ;;
            *)
                log "Unknown health status: ${health_status}"
                ;;
        esac

        if [ $waited -ge $MAX_WAIT_SECONDS ]; then
            log "WARNING: Timeout waiting for ${SERVICE_NAME} to be healthy (status: ${health_status}), proceeding anyway..."
            return 1
        fi

        sleep 1
        waited=$((waited + 1))

        if [ $((waited % 5)) -eq 0 ]; then
            log "Still waiting for ${SERVICE_NAME} to be healthy... ($waited/$MAX_WAIT_SECONDS, status: ${health_status})"
        fi
    done
}

# Cleanup function - called when MCP wrapper exits (Claude Desktop quit)
cleanup_on_exit() {
    local exit_code=$?
    
    # Release lock if we still hold it
    release_lock
    
    # Check if we're the instance that started compose
    if [ "$I_STARTED_COMPOSE" = true ] && [ -f "$STARTER_FILE" ]; then
        local starter_pid
        starter_pid=$(cat "$STARTER_FILE" 2>/dev/null)
        if [ "$starter_pid" = "$$" ]; then
            log "Claude Desktop quit - we started compose, shutting it down..."
            compose down >> "$LOG_FILE" 2>&1
            rm -f "$STARTER_FILE"
            log "Compose shutdown complete"
        fi
    fi
    
    exit $exit_code
}

log "mcp-exec starting with args: $@"

# Check if service is running
if ! is_service_running; then
    log "Service ${SERVICE_NAME} is not running, need to start composition..."

    if acquire_lock; then
        log "Lock acquired, checking again if service is running..."

        if ! is_service_running; then
            log "Service still not running, starting the composition..."

            # Clean up any stale containers first
            compose down --remove-orphans >> "$LOG_FILE" 2>&1 || true

            # Start compose stack using compose-dev wrapper
            (cd "$COMPOSE_DIR" && ./compose-dev up --daemon) >> "$LOG_FILE" 2>&1

            compose_exit=$?

            if [ $compose_exit -ne 0 ]; then
                log "ERROR: compose-dev up failed with exit code $compose_exit"
                release_lock
                exit 1
            fi

            # Mark ourselves as the starter
            echo $$ > "$STARTER_FILE"
            I_STARTED_COMPOSE=true
            log "Compose started successfully (we are the starter: PID $$)"
        else
            log "Service was started by another instance while waiting for lock"
        fi
    else
        log "Could not acquire lock, assuming another instance is handling startup"
    fi

    log "Waiting for service to appear..."

    waited=0
    while ! is_service_running; do
        if [ $waited -ge $MAX_WAIT_SECONDS ]; then
            log "ERROR: Timeout waiting for service ${SERVICE_NAME} to start"
            release_lock
            exit 1
        fi
        sleep 1
        waited=$((waited + 1))
        if [ $((waited % 5)) -eq 0 ]; then
            log "Waiting for service... ($waited/$MAX_WAIT_SECONDS)"
        fi
    done

    # NOW release lock - service is confirmed running
    release_lock

    log "Service is running, waiting for health check to pass..."
    wait_for_healthy
    log "Service ${SERVICE_NAME} is ready"
fi

log "Executing MCP wrapper in service container..."

# Set up cleanup trap - will fire when docker compose exec terminates
trap cleanup_on_exit EXIT

# Run MCP wrapper via docker compose exec
compose exec -T "${SERVICE_NAME}" node /home/emacs-user/lisply-mcp/scripts/mcp-wrapper.js "$@"

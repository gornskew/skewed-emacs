#!/usr/bin/env bash
# Build script for Skewed Emacs (public-repo friendly)

set -euo pipefail

cd "$(dirname "$0")"
DOCKER_DIR="$(pwd)"
PROJECT_ROOT="$(cd "$DOCKER_DIR/.." && pwd)"

DOCKERFILE_PATH="$DOCKER_DIR/Dockerfile"
BUILD_CONTEXT="$PROJECT_ROOT"   # original script used ".." as context

# -----------------------------
# CLI args
# -----------------------------
# CLI overrides (higher priority than auto-detect)
CLI_SET_PUSH=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-push)
      CLI_SET_PUSH="false"
      shift
      ;;
    --push)
      CLI_SET_PUSH="true"
      shift
      ;;
    -h|--help)
      cat <<EOF
Usage: $0 [OPTIONS]

Options:
  --push       Enable pushing the built image to Docker Hub
  --no-push    Skip pushing (build only)
  -h, --help   Show this help message

Behavior:
  - If PUSH_IMAGE is set in the environment, it is respected.
  - Else if --push/--no-push is given, it is respected.
  - Else auto-push is enabled only if:
      \$HOME/.docker-dockerhub-gornskew/config.json exists AND
      it contains an auth entry for "https://index.docker.io/v1/".
  - Otherwise defaults to build-only (public repo default).
EOF
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      echo "Use --help for usage information" >&2
      exit 1
      ;;
  esac
done

# -----------------------------
# Branch/tag logic
# -----------------------------
branch="dev"
if [ -n "${CI_COMMIT_REF_NAME:-}" ]; then
  branch="$CI_COMMIT_REF_NAME"
elif git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  branch="$(git -C "$PROJECT_ROOT" rev-parse --abbrev-ref HEAD)"
fi
branch="${branch//\//--}"
TAG="$branch"

# -----------------------------
# Push defaults (public-friendly)
# -----------------------------
# Dedicated push-config (same as lisply-mcp)
PUSH_DOCKER_CONFIG="${PUSH_DOCKER_CONFIG:-$HOME/.docker-dockerhub-gornskew}"
cfg="$PUSH_DOCKER_CONFIG/config.json"

# Determine PUSH_IMAGE precedence:
# 1) env var PUSH_IMAGE
# 2) CLI flags
# 3) auto-detect based on push config presence+content
if [ -n "${PUSH_IMAGE:-}" ]; then
  : # respect env
elif [ -n "$CLI_SET_PUSH" ]; then
  PUSH_IMAGE="$CLI_SET_PUSH"
else
  if [ -f "$cfg" ] && grep -q '"https://index.docker.io/v1/"' "$cfg"; then
    PUSH_IMAGE="true"
  else
    PUSH_IMAGE="false"
  fi
fi

# Namespace/tagging behavior:
# - If pushing, default to gornskew unless user set DOCKER_USERNAME
# - If not pushing, default to localbuild so anons don't tag gornskew/*
if [[ "$PUSH_IMAGE" == "true" ]]; then
  DOCKER_USERNAME="${DOCKER_USERNAME:-gornskew}"
else
  DOCKER_USERNAME="${DOCKER_USERNAME:-localbuild}"
fi

IMAGE_NAME="${DOCKER_USERNAME}/skewed-emacs"

# -----------------------------
# Preflight
# -----------------------------
echo "=== Building Skewed Emacs Docker Image ==="
echo "Project root:     $PROJECT_ROOT"
echo "Dockerfile:       $DOCKERFILE_PATH"
echo "Build context:    $BUILD_CONTEXT"
echo "Tag:              ${IMAGE_NAME}:${TAG}"
echo "Push:             ${PUSH_IMAGE}"
echo "Push docker cfg:  ${PUSH_DOCKER_CONFIG}"

if [ ! -f "$DOCKERFILE_PATH" ]; then
  echo "Error: Dockerfile not found at $DOCKERFILE_PATH" >&2
  exit 1
fi


# For local development, always also tag as gornskew/skewed-emacs:* so compose picks it up
if [[ "$PUSH_IMAGE" == "false" ]]; then
  FINAL_IMAGE="gornskew/skewed-emacs"
  EXTRA_TAGS="-t ${FINAL_IMAGE}:${TAG} -t ${FINAL_IMAGE}:latest"
else
  FINAL_IMAGE="${IMAGE_NAME}"
  EXTRA_TAGS=""
fi

# -----------------------------
# Build
# -----------------------------

# For local development, always tag as gornskew/skewed-emacs:* so compose picks it up
if [[ "$PUSH_IMAGE" == "false" ]]; then
  FINAL_IMAGE="gornskew/skewed-emacs"
  LOCAL_TAGS="-t ${FINAL_IMAGE}:${TAG} -t ${FINAL_IMAGE}:latest"
else
  FINAL_IMAGE="${IMAGE_NAME}"
  LOCAL_TAGS=""
fi

echo "=== Building Skewed Emacs Docker Image ==="
echo "Project root:     $PROJECT_ROOT"
echo "Dockerfile:       $DOCKERFILE_PATH"
echo "Build context:    $BUILD_CONTEXT"
echo "Primary tag:      ${IMAGE_NAME}:${TAG}"
echo "Additional tags:  ${FINAL_IMAGE}:${TAG} ${FINAL_IMAGE}:latest (if applicable)"
echo "Push:             ${PUSH_IMAGE}"

DOCKER_BUILDKIT=1 docker build \
  --progress=plain \
  -t "${IMAGE_NAME}:${TAG}" \
  ${LOCAL_TAGS} \
  --build-arg GIT_BRANCH="${branch}" \
  -f "$DOCKERFILE_PATH" \
  "$BUILD_CONTEXT"

# Always tag :latest on main/master/devo branches — using the FINAL_IMAGE
if [[ "${TAG}" == "main" || "${TAG}" == "master" || "${TAG}" == "devo" ]]; then
  docker tag "${IMAGE_NAME}:${TAG}" "${FINAL_IMAGE}:latest"
  echo "Also tagged as:  ${FINAL_IMAGE}:latest"
fi

# -----------------------------
# Exfiltrate generated configs from image back to repo
# -----------------------------
echo ""
echo "Extracting generated configs from image..."
TEMP_CONTAINER=$(docker create "${IMAGE_NAME}:${TAG}")
docker cp "${TEMP_CONTAINER}:/home/emacs-user/skewed-emacs/mcp/mcp-windows.json" "${PROJECT_ROOT}/mcp/mcp-windows.json" 2>/dev/null || true
docker cp "${TEMP_CONTAINER}:/home/emacs-user/skewed-emacs/mcp/mcp-container.json" "${PROJECT_ROOT}/mcp/mcp-container.json" 2>/dev/null || true
docker cp "${TEMP_CONTAINER}:/home/emacs-user/skewed-emacs/mcp/mcp.toml" "${PROJECT_ROOT}/mcp/mcp.toml" 2>/dev/null || true
docker cp "${TEMP_CONTAINER}:/home/emacs-user/skewed-emacs/docker-compose.yml" "${PROJECT_ROOT}/docker-compose.yml" 2>/dev/null || true
docker rm "${TEMP_CONTAINER}" > /dev/null
echo "Generated configs extracted to repo."

echo ""
echo "=== Build Complete ==="
echo "Image tagged as: ${IMAGE_NAME}:${TAG}"
if [[ -n "$LOCAL_TAGS" ]]; then
  echo "Also tagged as:  ${FINAL_IMAGE}:${TAG}"
  echo "And:             ${FINAL_IMAGE}:latest"
fi
echo ""
echo "To test the container:"
echo "  ./compose-dev up --build"
echo "  docker run -p 7081:7080 -p 6942:6942 ${FINAL_IMAGE}:${TAG}"
echo ""

# -----------------------------
# Push (optional)
# -----------------------------
if [[ "$PUSH_IMAGE" == "true" ]]; then
  echo "Push enabled."

  if [[ "$DOCKER_USERNAME" == "localbuild" ]]; then
    echo "Error: PUSH_IMAGE=true but DOCKER_USERNAME resolved to 'localbuild'." >&2
    echo "Set DOCKER_USERNAME=gornskew (or appropriate namespace) to push." >&2
    exit 2
  fi

  if [ -n "${DOCKER_PASSWORD:-}" ]; then
    echo "Logging into Docker Hub (non-interactive)..."
    echo "${DOCKER_PASSWORD}" | docker --config "$PUSH_DOCKER_CONFIG" login -u "${DOCKER_USERNAME}" --password-stdin
  else
    echo "No DOCKER_PASSWORD provided; assuming existing credentials in: $PUSH_DOCKER_CONFIG"
  fi

  echo "Pushing ${IMAGE_NAME}:${TAG} ..."
  docker --config "$PUSH_DOCKER_CONFIG" push "${IMAGE_NAME}:${TAG}"

  if [[ "${TAG}" == "main" || "${TAG}" == "master" || "${TAG}" == "devo" ]]; then
    echo "Pushing ${IMAGE_NAME}:latest ..."
    docker --config "$PUSH_DOCKER_CONFIG" push "${IMAGE_NAME}:latest"
  fi

  echo "Push complete."
else
  echo "Skipping push (--no-push or no credentials)."
fi

echo ""
echo "Done with docker build job."
echo ""

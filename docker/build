#!/usr/bin/env bash
# Skewed Emacs build — safe multi-arch with manifest-aware canonical tags

set -euo pipefail

cd "$(dirname "$0")"
DOCKER_DIR="$(pwd)"
PROJECT_ROOT="$(cd "$DOCKER_DIR/.." && pwd)"

DOCKERFILE_PATH="$DOCKER_DIR/Dockerfile"
BUILD_CONTEXT="$PROJECT_ROOT"

# -----------------------------
# Defaults
# -----------------------------
TARGETS=""
PLATFORMS=""
CLI_SET_PUSH=""
CLI_SET_BUILD_INDEX="true"

# -----------------------------
# Help
# -----------------------------
show_help() {
  cat <<'EOF'
Usage: docker/build [OPTIONS]

Normal dev (single-arch, non-clobbering):
  docker/build --all --push
    - builds your native arch only
    - pushes arch-suffixed tags (e.g. devo-lite-amd64)
    - updates multi-arch manifests for canonical tags (devo-lite, devo-full, devo, latest, etc.)

Multi-arch on one machine:
  docker/build --all --multi-arch --push
    - builds amd64+arm64 at once via buildx
    - pushes canonical multi-arch tags directly

Targets:
  --all                 lite, aituis, gui, gui-aituis
  --lite
  --aituis, --tui
  --gui
  --gui-aituis, --full

Branch:
  --branch=NAME         override branch (default: current git branch, or devo)

Search index:
  --with-search-index   build skewed_search index (default)
  --no-search-index     skip skewed_search index

Push:
  --push                push images
  --no-push             do not push (default)

Multi-arch:
  --multi-arch          shorthand for --platforms=linux/amd64,linux/arm64
  --platforms=PLATFORMS explicit platforms for buildx (implies --push)

EOF
}

# -----------------------------
# Argument parsing
# -----------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) show_help; exit 0 ;;
    --all) TARGETS="lite aituis gui gui-aituis"; shift ;;
    --lite) TARGETS="$TARGETS lite"; shift ;;
    --aituis|--tui) TARGETS="$TARGETS aituis"; shift ;;
    --gui) TARGETS="$TARGETS gui"; shift ;;
    --gui-aituis|--full) TARGETS="$TARGETS gui-aituis"; shift ;;
    --branch=*) OVERRIDE_BRANCH="${1#*=}"; shift ;;
    --push) CLI_SET_PUSH="true"; shift ;;
    --no-push) CLI_SET_PUSH="false"; shift ;;
    --multi-arch) PLATFORMS="linux/amd64,linux/arm64"; shift ;;
    --platforms=*) PLATFORMS="${1#*=}"; shift ;;
    --with-search-index) CLI_SET_BUILD_INDEX="true"; shift ;;
    --no-search-index) CLI_SET_BUILD_INDEX="false"; shift ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

[[ -z "$TARGETS" ]] && TARGETS="lite aituis gui gui-aituis"
TARGETS=$(echo "$TARGETS" | tr ' ' '\n' | sort -u | tr '\n' ' ')

# -----------------------------
# Branch detection
# -----------------------------
if [[ -n "${OVERRIDE_BRANCH:-}" ]]; then
  branch="$OVERRIDE_BRANCH"
elif [[ -n "${CI_COMMIT_REF_NAME:-}" ]]; then
  branch="$CI_COMMIT_REF_NAME"
else
  branch="$(git -C "$PROJECT_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || echo devo)"
fi
branch="${branch//\//-}"

# -----------------------------
# lisply-mcp revision
# -----------------------------
echo "Fetching latest commit from lisply-mcp for branch ${branch}..."
LISPLY_MCP_REVISION=$(curl -s "https://api.github.com/repos/gornskew/lisply-mcp/git/refs/heads/${branch}" \
  | grep '"sha"' | head -1 | cut -d'"' -f4 || echo "latest")
if [[ -z "$LISPLY_MCP_REVISION" ]]; then
  echo "Warning: Could not fetch lisply-mcp revision, falling back to 'latest'"
  LISPLY_MCP_REVISION="latest"
fi
echo "lisply-mcp revision: ${LISPLY_MCP_REVISION}"

# -----------------------------
# Platform & builder mode
# -----------------------------
NATIVE_PLATFORM="$(docker version -f '{{.Server.Os}}/{{.Server.Arch}}' 2>/dev/null || echo linux/amd64)"
ARCH_SUFFIX="${NATIVE_PLATFORM#*/}"   # amd64 or arm64

if [[ -n "$PLATFORMS" ]]; then
  USE_BUILDX="multi"
  CLI_SET_PUSH="true"
else
  PLATFORMS="$NATIVE_PLATFORM"
  USE_BUILDX="single"
fi

PUSH_IMAGE="${CLI_SET_PUSH:-false}"

IMAGE_NAME="gornskew/skewed-emacs"
FINAL_IMAGE="gornskew/skewed-emacs"

# -----------------------------
# Stage mapping
# -----------------------------
get_stage_for_target() {
  case "$1" in
    lite)        echo "runtime-base" ;;
    aituis)      echo "runtime-aituis" ;;
    gui)         echo "runtime-gui" ;;
    gui-aituis)  echo "runtime-gui-aituis" ;;
    *)           echo "" ;;
  esac
}

# -----------------------------
# Build one target (single-arch)
# -----------------------------
build_target_single_arch() {
  local target="$1" stage="$2"
  local base_tag="${branch}-${target}"
  local arch_tag="${base_tag}-${ARCH_SUFFIX}"
  local build_index="${CLI_SET_BUILD_INDEX}"

  echo ""
  echo "=== Building ${IMAGE_NAME}:${arch_tag} (single-arch ${NATIVE_PLATFORM}) ==="

  local cmd=(docker build)
  local args=(
    "--progress=plain"
    "--platform" "${NATIVE_PLATFORM}"
    "--target" "${stage}"
    "-t" "${IMAGE_NAME}:${arch_tag}"
    "-t" "${FINAL_IMAGE}:${arch_tag}"
    "--build-arg" "GIT_BRANCH=${branch}"
    "--build-arg" "SKEWED_BUILD_SKEWED_INDEX=${build_index}"
    "--build-arg" "LISPLY_MCP_REVISION=${LISPLY_MCP_REVISION}"
    "-f" "${DOCKERFILE_PATH}"
    "${BUILD_CONTEXT}"
  )

  DOCKER_BUILDKIT=1 "${cmd[@]}" "${args[@]}"

  echo "✓ Built ${IMAGE_NAME}:${arch_tag}"

  if [[ "$PUSH_IMAGE" == "true" ]]; then
    echo "→ Pushing ${IMAGE_NAME}:${arch_tag}"
    docker push "${IMAGE_NAME}:${arch_tag}"
  fi
}

# -----------------------------
# Build one target (multi-arch)
# -----------------------------
build_target_multi_arch() {
  local target="$1" stage="$2"
  local base_tag="${branch}-${target}"
  local build_index="${CLI_SET_BUILD_INDEX}"

  echo ""
  echo "=== Building ${IMAGE_NAME}:${base_tag} (multi-arch: ${PLATFORMS}) ==="

  if ! docker buildx version >/dev/null 2>&1; then
    echo "Error: docker buildx not available" >&2
    exit 1
  fi

  local cmd=(docker buildx build)
  local args=(
    "--platform" "${PLATFORMS}"
    "--progress=plain"
    "--target" "${stage}"
    "-t" "${IMAGE_NAME}:${base_tag}"
    "--build-arg" "GIT_BRANCH=${branch}"
    "--build-arg" "SKEWED_BUILD_SKEWED_INDEX=${build_index}"
    "--build-arg" "LISPLY_MCP_REVISION=${LISPLY_MCP_REVISION}"
    "-f" "${DOCKERFILE_PATH}"
    "${BUILD_CONTEXT}"
  )

  if [[ "$PUSH_IMAGE" == "true" ]]; then
    args=(--push "${args[@]}")
  else
    args=(--load "${args[@]}")
  fi

  DOCKER_BUILDKIT=1 "${cmd[@]}" "${args[@]}"

  echo "✓ Built ${IMAGE_NAME}:${base_tag} (multi-arch buildx)"
}

# -----------------------------
# Create arch-suffixed aliases (local)
# -----------------------------
create_arch_aliases_local() {
  echo ""
  echo "=== Creating arch-suffixed local aliases for branch ${branch} (${ARCH_SUFFIX}) ==="

  local has_aituis=false
  local has_gui_aituis=false

  for target in $TARGETS; do
    [[ "$target" == "aituis" ]] && has_aituis=true
    [[ "$target" == "gui-aituis" ]] && has_gui_aituis=true
  done

  # {branch}-tui-{arch} → {branch}-aituis-{arch}
  if $has_aituis; then
    if docker image inspect "${FINAL_IMAGE}:${branch}-aituis-${ARCH_SUFFIX}" >/dev/null 2>&1; then
      docker tag "${FINAL_IMAGE}:${branch}-aituis-${ARCH_SUFFIX}" "${FINAL_IMAGE}:${branch}-tui-${ARCH_SUFFIX}"
      echo "✓ ${branch}-tui-${ARCH_SUFFIX} → ${branch}-aituis-${ARCH_SUFFIX}"
    fi
  fi

  # {branch}-full-{arch} → {branch}-gui-aituis-{arch}
  # {branch}-{arch}      → {branch}-full-{arch}
  if $has_gui_aituis; then
    if docker image inspect "${FINAL_IMAGE}:${branch}-gui-aituis-${ARCH_SUFFIX}" >/dev/null 2>&1; then
      docker tag "${FINAL_IMAGE}:${branch}-gui-aituis-${ARCH_SUFFIX}" "${FINAL_IMAGE}:${branch}-full-${ARCH_SUFFIX}"
      echo "✓ ${branch}-full-${ARCH_SUFFIX} → ${branch}-gui-aituis-${ARCH_SUFFIX}"

      docker tag "${FINAL_IMAGE}:${branch}-full-${ARCH_SUFFIX}" "${FINAL_IMAGE}:${branch}-${ARCH_SUFFIX}"
      echo "✓ ${branch}-${ARCH_SUFFIX} → ${branch}-full-${ARCH_SUFFIX}"

      if [[ "${branch}" == "devo" ]]; then
        docker tag "${FINAL_IMAGE}:devo-${ARCH_SUFFIX}" "${FINAL_IMAGE}:latest-${ARCH_SUFFIX}"
        echo "✓ latest-${ARCH_SUFFIX} → devo-${ARCH_SUFFIX}"
      fi
    fi
  fi
}

# -----------------------------
# Push arch-suffixed aliases
# -----------------------------
push_arch_aliases() {
  [[ "$PUSH_IMAGE" != "true" ]] && return

  echo ""
  echo "=== Pushing arch-suffixed aliases for branch ${branch} (${ARCH_SUFFIX}) ==="

  local tags_to_push=()

  # Real targets
  for t in $TARGETS; do
    tags_to_push+=("${branch}-${t}-${ARCH_SUFFIX}")
  done

  # Aliases: -tui, -full, branch, latest (for devo)
  if docker image inspect "${FINAL_IMAGE}:${branch}-tui-${ARCH_SUFFIX}" >/dev/null 2>&1; then
    tags_to_push+=("${branch}-tui-${ARCH_SUFFIX}")
  fi
  if docker image inspect "${FINAL_IMAGE}:${branch}-full-${ARCH_SUFFIX}" >/dev/null 2>&1; then
    tags_to_push+=("${branch}-full-${ARCH_SUFFIX}")
  fi
  if docker image inspect "${FINAL_IMAGE}:${branch}-${ARCH_SUFFIX}" >/dev/null 2>&1; then
    tags_to_push+=("${branch}-${ARCH_SUFFIX}")
  fi
  if [[ "${branch}" == "devo" ]] && docker image inspect "${FINAL_IMAGE}:latest-${ARCH_SUFFIX}" >/dev/null 2>&1; then
    tags_to_push+=("latest-${ARCH_SUFFIX}")
  fi

  # Deduplicate
  tags_to_push=($(printf "%s\n" "${tags_to_push[@]}" | sort -u))

  for tag in "${tags_to_push[@]}"; do
    echo "→ Pushing ${IMAGE_NAME}:${tag}"
    docker push "${IMAGE_NAME}:${tag}"
  done
}

# -----------------------------
# Manifest updater (canonical tags)
# -----------------------------
update_multi_arch_manifests() {
  [[ "$PUSH_IMAGE" != "true" ]] && return

  echo ""
  echo "=== Updating multi-arch manifests for canonical tags ==="

  local canonical_tags=()

  # Intermediate variants
  canonical_tags+=("${branch}-lite" "${branch}-aituis" "${branch}-gui" "${branch}-gui-aituis")

  # Aliases
  canonical_tags+=("${branch}-tui" "${branch}-full" "${branch}")

  # devo-only latest
  [[ "$branch" == "devo" ]] && canonical_tags+=("latest")

  # For each canonical tag, merge available -amd64 and -arm64
  for base in "${canonical_tags[@]}"; do
    local sources=()

    for arch in amd64 arm64; do
      if docker buildx imagetools inspect "${IMAGE_NAME}:${base}-${arch}" >/dev/null 2>&1; then
        sources+=("${IMAGE_NAME}:${base}-${arch}")
      fi
    done

    # If multi-arch buildx already pushed canonical directly, include it too
    if docker buildx imagetools inspect "${IMAGE_NAME}:${base}" >/dev/null 2>&1; then
      sources+=("${IMAGE_NAME}:${base}")
    fi

    if [[ ${#sources[@]} -gt 0 ]]; then
      echo "→ ${IMAGE_NAME}:${base} ← ${sources[*]}"
      docker buildx imagetools create -t "${IMAGE_NAME}:${base}" "${sources[@]}"
    fi
  done

  echo "✓ Manifests updated"
}

# -----------------------------
# Config extraction (from best local image)
# -----------------------------
extract_generated_configs() {
  echo ""
  echo "=== Extracting generated configs from image (if available) ==="

  local preferred=""
  if [[ " $TARGETS " =~ " gui-aituis " ]]; then
    preferred="gui-aituis"
  elif [[ " $TARGETS " =~ " gui " ]]; then
    preferred="gui"
  elif [[ " $TARGETS " =~ " aituis " ]]; then
    preferred="aituis"
  else
    preferred="lite"
  fi

  local tag_candidate="${FINAL_IMAGE}:${branch}-${preferred}-${ARCH_SUFFIX}"

  if ! docker image inspect "${tag_candidate}" >/dev/null 2>&1; then
    echo "No local image ${tag_candidate} found; skipping config extraction."
    return
  fi

  local temp_container
  temp_container=$(docker create "${tag_candidate}")
  docker cp "${temp_container}:/home/emacs-user/skewed-emacs/mcp/mcp-windows.json" "${PROJECT_ROOT}/mcp/mcp-windows.json" 2>/dev/null || true
  docker cp "${temp_container}:/home/emacs-user/skewed-emacs/mcp/mcp-container.json" "${PROJECT_ROOT}/mcp/mcp-container.json" 2>/dev/null || true
  docker cp "${temp_container}:/home/emacs-user/skewed-emacs/mcp/mcp.toml" "${PROJECT_ROOT}/mcp/mcp.toml" 2>/dev/null || true
  docker cp "${temp_container}:/home/emacs-user/skewed-emacs/docker-compose.yml" "${PROJECT_ROOT}/docker-compose.yml" 2>/dev/null || true
  docker rm "${temp_container}" >/dev/null

  echo "✓ Generated configs extracted (if present)"
}

# -----------------------------
# Main
# -----------------------------
echo "═══════════════════════════════════════════════════════════════"
echo "Skewed Emacs Build"
echo "═══════════════════════════════════════════════════════════════"
echo "Project root:     $PROJECT_ROOT"
echo "Dockerfile:       $DOCKERFILE_PATH"
echo "Branch:           ${branch}"
echo "Native platform:  ${NATIVE_PLATFORM}"
echo "Requested plats:  ${PLATFORMS}"
echo "Mode:             ${USE_BUILDX}"
echo "Targets:          $TARGETS"
echo "Image name:       ${IMAGE_NAME}"
echo "Push:             ${PUSH_IMAGE}"
echo "Search index:     ${CLI_SET_BUILD_INDEX}"
echo "═══════════════════════════════════════════════════════════════"

if [[ ! -f "$DOCKERFILE_PATH" ]]; then
  echo "Error: Dockerfile not found at $DOCKERFILE_PATH" >&2
  exit 1
fi

for target in $TARGETS; do
  stage="$(get_stage_for_target "$target")"
  if [[ -z "$stage" ]]; then
    echo "Error: Unknown target '$target'" >&2
    exit 1
  fi

  if [[ "$USE_BUILDX" == "multi" ]]; then
    build_target_multi_arch "$target" "$stage"
  else
    build_target_single_arch "$target" "$stage"
  fi
done

# Only meaningful in single-arch mode (multi-arch mode uses canonical tags directly)
if [[ "$USE_BUILDX" == "single" ]]; then
  create_arch_aliases_local
  push_arch_aliases
fi

extract_generated_configs
update_multi_arch_manifests

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "Done!"
echo "═══════════════════════════════════════════════════════════════"
echo ""
echo "Examples:"
echo "  docker pull ${IMAGE_NAME}:${branch}-full"
echo "  docker run -p 7081:7080 -p 6942:6942 ${IMAGE_NAME}:${branch}-full"
echo ""

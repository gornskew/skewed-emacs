#!/usr/bin/env bash
# Build script for Skewed Emacs with branch-prefixed additive naming

set -euo pipefail

cd "$(dirname "$0")"
DOCKER_DIR="$(pwd)"
PROJECT_ROOT="$(cd "$DOCKER_DIR/.." && pwd)"

DOCKERFILE_PATH="$DOCKER_DIR/Dockerfile"
BUILD_CONTEXT="$PROJECT_ROOT"

# -----------------------------
# Default values
# -----------------------------
TARGETS=""  # Empty means build all targets
CLI_SET_PUSH=""

# -----------------------------
# Help text
# -----------------------------
show_help() {
  cat <<'EOF'
Usage: docker/build [OPTIONS]

Build Skewed Emacs container images with branch-prefixed additive naming.

Build Targets (can specify multiple):
  --all                 Build all variants (default if no targets specified)
  --lite                Build {branch}-lite (base only)
  --aituis, --tui       Build {branch}-aituis (base + AI CLIs)
  --gui                 Build {branch}-gui (base + GUI)
  --gui-aituis, --full  Build {branch}-gui-aituis (everything)

Branch Control:
  --branch=NAME         Build for specific branch (auto-detected by default)

Push Control:
  --push                Enable pushing to Docker Hub
  --no-push             Skip pushing (build only, default for public repos)

Legacy Options (deprecated, use targets instead):
  --variant=full|lite   Legacy variant selection (use --gui-aituis or --lite)

Examples:
  # Build all variants for current branch
  docker/build --all

  # Build only lite and gui variants for devo
  docker/build --lite --gui --branch=devo

  # Build and push full variant for master
  docker/build --full --push --branch=master

  # Build everything and push
  docker/build --all --push

Naming Scheme:
  {branch}-lite         Base (emacs-nox, vterm, lisply-mcp, ttyd) ~800MB
  {branch}-aituis       Base + AI CLIs ~1.3GB
  {branch}-gui          Base + GUI support ~1.2GB  
  {branch}-gui-aituis   Everything ~1.7GB

Aliases (auto-created):
  {branch}-tui      → {branch}-aituis
  {branch}-full     → {branch}-gui-aituis
  {branch}          → {branch}-full
  latest            → devo (devo branch only)

Options:
  -h, --help       Show this help message
EOF
}

# -----------------------------
# Parse arguments
# -----------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      show_help
      exit 0
      ;;
    --all)
      TARGETS="lite aituis gui gui-aituis"
      shift
      ;;
    --lite)
      TARGETS="$TARGETS lite"
      shift
      ;;
    --aituis|--tui)
      TARGETS="$TARGETS aituis"
      shift
      ;;
    --gui)
      TARGETS="$TARGETS gui"
      shift
      ;;
    --gui-aituis|--full)
      TARGETS="$TARGETS gui-aituis"
      shift
      ;;
    --branch=*)
      OVERRIDE_BRANCH="${1#*=}"
      shift
      ;;
    --push)
      CLI_SET_PUSH="true"
      shift
      ;;
    --no-push)
      CLI_SET_PUSH="false"
      shift
      ;;
    # Legacy options (deprecated)
    --variant=*)
      LEGACY_VARIANT="${1#*=}"
      echo "Warning: --variant is deprecated. Use --lite or --full instead." >&2
      if [[ "$LEGACY_VARIANT" == "lite" ]]; then
        TARGETS="$TARGETS lite"
      else
        TARGETS="$TARGETS gui-aituis"
      fi
      shift
      ;;
    *)
      echo "Unknown option: $1" >&2
      echo "Use --help for usage information" >&2
      exit 1
      ;;
  esac
done

# Default to building all if no targets specified
if [[ -z "$TARGETS" ]]; then
  TARGETS="lite aituis gui gui-aituis"
fi

# Remove duplicates from TARGETS
TARGETS=$(echo "$TARGETS" | tr ' ' '\n' | sort -u | tr '\n' ' ')

# -----------------------------
# Branch detection
# -----------------------------
if [ -n "${OVERRIDE_BRANCH:-}" ]; then
  branch="$OVERRIDE_BRANCH"
elif [ -n "${CI_COMMIT_REF_NAME:-}" ]; then
  branch="$CI_COMMIT_REF_NAME"
elif git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  branch="$(git -C "$PROJECT_ROOT" rev-parse --abbrev-ref HEAD)"
else
  branch="devo"
fi
branch="${branch//\//--}"  # Replace / with -- in branch names

# -----------------------------
# Push configuration
# -----------------------------
PUSH_DOCKER_CONFIG="${PUSH_DOCKER_CONFIG:-$HOME/.docker-dockerhub-gornskew}"
cfg="$PUSH_DOCKER_CONFIG/config.json"

# Determine PUSH_IMAGE
if [ -n "${PUSH_IMAGE:-}" ]; then
  : # respect env var
elif [ -n "$CLI_SET_PUSH" ]; then
  PUSH_IMAGE="$CLI_SET_PUSH"
else
  if [ -f "$cfg" ] && grep -q '"https://index.docker.io/v1/"' "$cfg"; then
    PUSH_IMAGE="true"
  else
    PUSH_IMAGE="false"
  fi
fi

# Namespace
if [[ "$PUSH_IMAGE" == "true" ]]; then
  DOCKER_USERNAME="${DOCKER_USERNAME:-gornskew}"
else
  DOCKER_USERNAME="${DOCKER_USERNAME:-localbuild}"
fi

IMAGE_NAME="${DOCKER_USERNAME}/skewed-emacs"

# For local development, always also tag as gornskew/skewed-emacs
if [[ "$PUSH_IMAGE" == "false" ]]; then
  FINAL_IMAGE="gornskew/skewed-emacs"
else
  FINAL_IMAGE="${IMAGE_NAME}"
fi

# -----------------------------
# Build function
# -----------------------------
build_target() {
  local target="$1"
  local stage="$2"
  local tag="${branch}-${target}"
  
  echo ""
  echo "═══════════════════════════════════════════════════════════════"
  echo "Building ${IMAGE_NAME}:${tag} (stage: ${stage})"
  echo "═══════════════════════════════════════════════════════════════"
  
  DOCKER_BUILDKIT=1 docker build \
    --progress=plain \
    --target "${stage}" \
    -t "${IMAGE_NAME}:${tag}" \
    -t "${FINAL_IMAGE}:${tag}" \
    --build-arg GIT_BRANCH="${branch}" \
    -f "$DOCKERFILE_PATH" \
    "$BUILD_CONTEXT"
  
  echo "✓ Built ${IMAGE_NAME}:${tag}"
}

# -----------------------------
# Create aliases function
# -----------------------------
create_aliases() {
  echo ""
  echo "═══════════════════════════════════════════════════════════════"
  echo "Creating aliases for ${branch} branch"
  echo "═══════════════════════════════════════════════════════════════"
  
  # Check which targets were built
  local has_aituis=false
  local has_gui_aituis=false
  
  for target in $TARGETS; do
    [[ "$target" == "aituis" ]] && has_aituis=true
    [[ "$target" == "gui-aituis" ]] && has_gui_aituis=true
  done
  
  # Create -tui alias if -aituis was built
  if $has_aituis; then
    docker tag "${FINAL_IMAGE}:${branch}-aituis" "${FINAL_IMAGE}:${branch}-tui"
    echo "✓ ${branch}-tui → ${branch}-aituis"
  fi
  
  # Create -full and branch aliases if -gui-aituis was built
  if $has_gui_aituis; then
    docker tag "${FINAL_IMAGE}:${branch}-gui-aituis" "${FINAL_IMAGE}:${branch}-full"
    echo "✓ ${branch}-full → ${branch}-gui-aituis"
    
    docker tag "${FINAL_IMAGE}:${branch}-full" "${FINAL_IMAGE}:${branch}"
    echo "✓ ${branch} → ${branch}-full"
    
    # Special: latest → devo (only for devo branch)
    if [[ "${branch}" == "devo" ]]; then
      docker tag "${FINAL_IMAGE}:devo" "${FINAL_IMAGE}:latest"
      echo "✓ latest → devo"
    fi
  fi
}

# -----------------------------
# Push function
# -----------------------------
push_images() {
  if [[ "$PUSH_IMAGE" != "true" ]]; then
    echo ""
    echo "Skipping push (use --push to enable)"
    return
  fi
  
  if [[ "$DOCKER_USERNAME" == "localbuild" ]]; then
    echo "Error: Cannot push with DOCKER_USERNAME=localbuild" >&2
    exit 2
  fi
  
  echo ""
  echo "═══════════════════════════════════════════════════════════════"
  echo "Pushing images to Docker Hub"
  echo "═══════════════════════════════════════════════════════════════"
  
  # Login if DOCKER_PASSWORD provided
  if [ -n "${DOCKER_PASSWORD:-}" ]; then
    echo "Logging into Docker Hub..."
    echo "${DOCKER_PASSWORD}" | docker --config "$PUSH_DOCKER_CONFIG" login -u "${DOCKER_USERNAME}" --password-stdin
  fi
  
  # Push canonical feature tags
  for target in $TARGETS; do
    local tag="${branch}-${target}"
    echo "→ Pushing ${IMAGE_NAME}:${tag}"
    docker --config "$PUSH_DOCKER_CONFIG" push "${IMAGE_NAME}:${tag}"
  done
  
  # Push aliases if they exist
  docker images --format "{{.Repository}}:{{.Tag}}" | grep "^${IMAGE_NAME}:" | while read img; do
    local tag="${img#*:}"
    # Only push aliases (tui, full, branch name, latest)
    if [[ "$tag" =~ ^(${branch}-tui|${branch}-full|${branch}|latest)$ ]]; then
      echo "→ Pushing ${img}"
      docker --config "$PUSH_DOCKER_CONFIG" push "${img}"
    fi
  done
  
  echo "✓ Push complete"
}

# -----------------------------
# Main execution
# -----------------------------
echo "═══════════════════════════════════════════════════════════════"
echo "Skewed Emacs Build"
echo "═══════════════════════════════════════════════════════════════"
echo "Project root:     $PROJECT_ROOT"
echo "Dockerfile:       $DOCKERFILE_PATH"
echo "Branch:           ${branch}"
echo "Targets:          $TARGETS"
echo "Image name:       ${IMAGE_NAME}"
echo "Push:             ${PUSH_IMAGE}"
echo "═══════════════════════════════════════════════════════════════"

if [ ! -f "$DOCKERFILE_PATH" ]; then
  echo "Error: Dockerfile not found at $DOCKERFILE_PATH" >&2
  exit 1
fi

# Map targets to Docker stages
declare -A STAGE_MAP=(
  [lite]="runtime-base"
  [aituis]="runtime-aituis"
  [gui]="runtime-gui"
  [gui-aituis]="runtime-gui-aituis"
)

# Build each target
for target in $TARGETS; do
  stage="${STAGE_MAP[$target]}"
  if [ -z "$stage" ]; then
    echo "Error: Unknown target '$target'" >&2
    exit 1
  fi
  build_target "$target" "$stage"
done

# Create aliases
create_aliases

# Show what was built
echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "Build complete! Image sizes:"
echo "═══════════════════════════════════════════════════════════════"
docker images "${FINAL_IMAGE}" --format "table {{.Repository}}:{{.Tag}}\t{{.Size}}" | grep -E "REPOSITORY|${branch}|latest"

# Extract generated configs from one of the images
echo ""
echo "Extracting generated configs from image..."
# Use the most complete image that was built
if [[ " $TARGETS " =~ " gui-aituis " ]]; then
  EXTRACT_TAG="${branch}-gui-aituis"
elif [[ " $TARGETS " =~ " gui " ]]; then
  EXTRACT_TAG="${branch}-gui"
elif [[ " $TARGETS " =~ " aituis " ]]; then
  EXTRACT_TAG="${branch}-aituis"
else
  EXTRACT_TAG="${branch}-lite"
fi

TEMP_CONTAINER=$(docker create "${FINAL_IMAGE}:${EXTRACT_TAG}")
docker cp "${TEMP_CONTAINER}:/home/emacs-user/skewed-emacs/mcp/mcp-windows.json" "${PROJECT_ROOT}/mcp/mcp-windows.json" 2>/dev/null || true
docker cp "${TEMP_CONTAINER}:/home/emacs-user/skewed-emacs/mcp/mcp-container.json" "${PROJECT_ROOT}/mcp/mcp-container.json" 2>/dev/null || true
docker cp "${TEMP_CONTAINER}:/home/emacs-user/skewed-emacs/mcp/mcp.toml" "${PROJECT_ROOT}/mcp/mcp.toml" 2>/dev/null || true
docker cp "${TEMP_CONTAINER}:/home/emacs-user/skewed-emacs/docker-compose.yml" "${PROJECT_ROOT}/docker-compose.yml" 2>/dev/null || true
docker rm "${TEMP_CONTAINER}" > /dev/null
echo "✓ Generated configs extracted"

# Push if requested
push_images

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "Done!"
echo "═══════════════════════════════════════════════════════════════"
echo ""
echo "Available tags:"
for target in $TARGETS; do
  echo "  ${FINAL_IMAGE}:${branch}-${target}"
done
echo ""
echo "To test:"
echo "  docker run -p 7081:7080 -p 6942:6942 ${FINAL_IMAGE}:${branch}"
echo ""

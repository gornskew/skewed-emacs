{
    "mcpServers": {
        "gendl-ccl": {
            "command": "node",
            "args": [
                "/home/emacs-user/lisply-mcp/scripts/mcp-wrapper.js",
                "--server-name", "gendl-ccl",
                "--http-host-port", "9081",
                "--http-port", "9080",
                "--backend-host", "gendl-ccl",
                "--mount", "/projects:/projects",
                "--mount", "/var/run/docker.sock:/var/run/docker.sock",
                "--mount", "/tmp/.X11-unix:/tmp/.X11-unix"
            ]
        },
        "gendl-sbcl": {
            "command": "node",
            "args": [
                "/home/emacs-user/lisply-mcp/scripts/mcp-wrapper.js",
                "--server-name", "gendl-sbcl",
                "--http-host-port", "9091",
                "--http-port", "9090",
                "--backend-host", "gendl-sbcl",
                "--mount", "/projects:/projects",
                "--mount", "/var/run/docker.sock:/var/run/docker.sock",
                "--mount", "/tmp/.X11-unix:/tmp/.X11-unix"
            ]
        },
        "skewed-emacs": {
            "command": "node",
            "args": [
                "/home/emacs-user/lisply-mcp/scripts/mcp-wrapper.js",
                "--server-name", "skewed-emacs",
                "--http-host-port", "7081",
                "--http-port", "7080",
                "--image-base-name", "gornskew/skewed-emacs",
                "--backend-host", "skewed-emacs",
                "--mount", "/projects:/projects",
                "--mount", "/tmp/.X11-unix:/tmp/.X11-unix",
                "--mount", "/var/run/docker.sock:/var/run/docker.sock"
            ]
        }
    }
}

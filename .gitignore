# ==============================================================================
# .dockerignore - Controls what gets sent to Docker build context
# NOTE: Intentionally mirrors .gitignore for consistency
# ==============================================================================

# ==============================================================================
# Emacs temporary/backup files
# ==============================================================================
*~
.#*
**/#*#
*.elc

# ==============================================================================
# Log files
# ==============================================================================
*.log
*.log*

# ==============================================================================
# Emacs user directories (regenerated, user-specific)
# ==============================================================================
dot-files/emacs.d/auto-save-list/
dot-files/emacs.d/eln-cache/
dot-files/emacs.d/elpa/
dot-files/emacs.d/elpa-archives/
dot-files/emacs.d/ellama-sessions/
dot-files/emacs.d/eshell/
dot-files/emacs.d/melpa/
dot-files/emacs.d/org-persist/
dot-files/emacs.d/quelpa/
dot-files/emacs.d/request/
dot-files/emacs.d/semanticdb/
dot-files/emacs.d/sideloaded/claude-code/
dot-files/emacs.d/straight/
dot-files/emacs.d/.straight/
dot-files/emacs.d/tramp
dot-files/emacs.d/transient/
dot-files/emacs.d/url/
dot-files/emacs.d/var/
dot-files/emacs.d/vterm/
dot-files/emacs.d/workspace/

# Emacs user state files
dot-files/emacs.d/.chatgpt-shell.el
dot-files/emacs.d/.dap-breakpoints
dot-files/emacs.d/.lsp-session*
dot-files/emacs.d/abbrev_defs
dot-files/emacs.d/custom.el
dot-files/emacs.d/ielm-history.eld
dot-files/emacs.d/network-security.data
dot-files/emacs.d/org-clock-save.el
dot-files/emacs.d/places
dot-files/emacs.d/projectile-bookmarks.eld
dot-files/emacs.d/recentf
dot-files/emacs.d/sideloaded/lisply-backend/skewed-search-index.json

# ==============================================================================
# Auth & secrets (never include in build)
# ==============================================================================
.authinfo
.authinfo.gpg
.env
.tokens/
*token*

# ==============================================================================
# Local user configuration
# ==============================================================================
.emacs-local
.emacs-local-early
custom.el*
private-mcp-config.json
overlays/local.sexp

# ==============================================================================
# Generated compose files (from services.sexp)
# ==============================================================================
genworks-gdl*.yml
betatest*.yml
enterprise*.yml

# Development overlay files (local, not committed)
*-overlay.yml

*-dev-overlay.yml

# ==============================================================================
# Generated MCP configs
# ==============================================================================
mcp/genworks-gdl*
mcp/betatest*
mcp/enterprise*
mcp/claude_desktop_config.json
**/genworks-gdl*.*
**/betatest*.*
**/enterprise*.*

# ==============================================================================
# Build artifacts & caches
# ==============================================================================
.cache/
.git/
.idea/
.npm/
.vscode/
__pycache__/
node_modules/
temp/
tmp/

# ==============================================================================
# History files
# ==============================================================================
.bash_history
history.*
.#*
dot-files/emacs.d/sideloaded/lisply-backend/skewed-search-config.json
